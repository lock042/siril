msgid "Filter: "
msgstr "Фильтр: "

#: src/gui-gtk4/uifiles/aavso_dialog.ui:110
msgid "The filter used for the observation."
msgstr "Фильтр, использованный для наблюдения."

#: src/gui-gtk4/uifiles/aavso_dialog.ui:120
msgid "Cname: "
