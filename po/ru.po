#: src/gui-gtk4/uifiles/aavso_dialog.ui:41
msgid ""
"The official AAVSO Observer Code for the observer which was previously "
"assigned by the AAVSO."
msgstr ""
"Официальный код наблюдателя AAVSO, ранее присвоенный Американской "
"ассоциацией наблюдателей переменных звёзд (AAVSO)."

#: src/gui-gtk4/uifiles/aavso_dialog.ui:52
