msgstr "X:"

#: src/gui-gtk4/uifiles/siril_plot.ui:191
#: src/gui-gtk4/uifiles/siril_plot.ui:217
#: src/gui-gtk4/uifiles/siril_registration.ui:1155
#: src/gui-gtk4/uifiles/siril_registration.ui:1268
#: src/gui-gtk4/uifiles/siril_registration.ui:1403
