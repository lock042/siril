msgstr "Stern-Neuzusammensetzung"

#: src/gui-gtk4/uifiles/epf_dialog.ui:51
msgid "Filter Type"
msgstr "Filtertyp"

#: src/gui-gtk4/uifiles/epf_dialog.ui:59
msgid "Bilateral filter"
msgstr "Beidseitiger Filter"

#: src/gui-gtk4/uifiles/epf_dialog.ui:60
msgid "Guided filter"
msgstr "geführter Filter"

#: src/gui-gtk4/uifiles/epf_dialog.ui:65
msgid ""
"Choose filter type. See the documentation for an explanation of the "
"differences."
msgstr ""
