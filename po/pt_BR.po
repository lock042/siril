#: src/gui-gtk4/uifiles/background_extraction_dialog.ui:492
msgid "Simplified model"
msgstr "Modelo simplificado"

#: src/gui-gtk4/uifiles/background_extraction_dialog.ui:493
msgid ""
"Replace the multiscale model with a stiff polynomial. Use it when a nebula "
