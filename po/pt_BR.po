#: src/gui/uifiles/s_pcc_dialog.ui:1274 src/gui/uifiles/s_pcc_dialog.ui:1292
#: src/gui/uifiles/settings_window.ui:512
#: src/gui/uifiles/settings_window.ui:527
msgid "0"
msgstr "0"

#: src/gui/uifiles/aavso_dialog.ui:326
msgid "Check star: "
msgstr "Estrela de controle: "

#: src/gui/uifiles/aavso_dialog.ui:337
msgid "The number of the check star."
msgstr "Número de estrelas de controle."

#: src/gui/uifiles/aavso_dialog.ui:349
msgid ""
"Please use the sequence ID you will find written in Bold print near the top "
"of the photometry table in a sentence that reads \"Report this sequence as "
"[ID] in the chart field of your observation report.\" If you used your own "
"comparison stars (e.g. in the case of time-sensitive alerts when the "
"Sequence Team had no time to create a sequence), do not give a chart ID, "
"even if you plotted the chart using VSP. Use the comment code K (non-AAVSO "
"chart) and give a proper chart name like \"APASS DR10\". Then add "
"information on the comp stars in the notes. Limit: 20 characters."
msgstr ""
"Por favor, use o ID da sequência que você encontrará escrito em negrito "
"próximo ao topo da tabela de fotometria em uma frase que diz \"Relate esta "
"sequência como [ID] no campo do gráfico do seu relatório de observação\". Se "
"você usou suas próprias estrelas de comparação (por exemplo, no caso de "
"alertas sensíveis ao tempo quando a equipe de sequência não teve tempo de "
"criar uma sequência), não forneça uma ID de gráfico, mesmo que você tenha "
"plotado o gráfico usando o VSP. Use o código de comentário K (gráfico não "
"AAVSO) e dê um nome de gráfico adequado como \"APASS DR10\". Em seguida, "
"adicione informações sobre as estrelas de comparação nas notas. Limite: 20 "
"caracteres."

#: src/gui/uifiles/aavso_dialog.ui:365
msgid "Chart: "
msgstr "Gráfico: "

#: src/gui/uifiles/aavso_dialog.ui:377
msgid "Notes: "
msgstr "Notas: "

#: src/gui/uifiles/aavso_dialog.ui:388
msgid "Comments or notes about the observation. If no comments, use \"na\"."
msgstr ""
"Comentários ou notas sobre a observação. Se não houver comentários, use "
"\"na\"."

