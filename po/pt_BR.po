#: src/gui/compositing.c:709 src/gui/compositing.c:1975
msgid "(None)"
msgstr "(Nenhum)"

#: src/gui/uifiles/composition_dialog.ui:330 src/gui/uifiles/pixelmath.ui:704
msgid "Sum exposure time"
msgstr "Soma do tempo de exposição"

#: src/gui/uifiles/composition_dialog.ui:334 src/gui/uifiles/pixelmath.ui:708
msgid ""
"Sum of the exposure times of the different images used for the composition. "
"This will change the value of some keywords such as STACKCNT (number of "
"frames stacked) and LIVETIME (total exposure)."
msgstr ""
"Soma dos tempos de exposição das diferentes imagens usadas na composição. "
"Isso alterará o valor de algumas palavras-chave, como STACKCNT (número de "
"quadros empilhados) e LIVETIME (exposição total)."

#: src/gui/uifiles/composition_dialog.ui:352
msgid "Linear match"
msgstr "Correspondência linear"

#: src/gui/uifiles/composition_dialog.ui:356
msgid ""
"Linear match the input layer images to the first layer.\n"
"This is important if you are not coloring the layers with pure R, pure G and "
"pure B."
msgstr ""
"Faça a correspondência linear das imagens da camada de entrada com a "
"primeira camada.\n"
"Isso é importante se você não estiver colorindo as camadas com R puro, G "
"puro e B puro."

#: src/gui/uifiles/composition_dialog.ui:368
msgid "Adjust layers brightness"
msgstr "Ajustar brilho de camadas"

#: src/gui/uifiles/composition_dialog.ui:372
msgid ""
"Automatically adjust the brightness of the colours picked for layers so that "
"they don't overflow when compositing (based on max value for each image). "
"Colour hues are unchanged."
msgstr ""
"Automaticamente, Ajustar o brilho das cores selecionadas para as camadas, de "
"forma a que não transborde quando se compõem(baseado no valor máximo para "
"cada imagem). A matiz das cores não se altera."

#: src/gui/uifiles/composition_dialog.ui:385
msgid ""
"Type of luminance-based colour composition. They represent the way of adding "
"colour information to luminance data."
msgstr ""
"Tipo de luminância baseada na composição de cor. Representa a forma de "
"adicionar informação de cor aos dados de luminância."

#: src/gui/uifiles/composition_dialog.ui:388
msgid "HSL composition"
msgstr "Composição HSL"

#: src/gui/uifiles/composition_dialog.ui:389
msgid "HSV composition"
msgstr "Composição HSV"

#: src/gui/uifiles/composition_dialog.ui:390
msgid "CIE L*a*b* composition"
msgstr "Composição CIE L*a*b*"

#: src/gui/uifiles/composition_dialog.ui:433
msgid "Use this alignment method:"
msgstr "Use este método de alinhamento:"

#: src/gui/uifiles/composition_dialog.ui:446
msgid "and this framing method:"
msgstr "e este método de enquadramento:"

#: src/gui/uifiles/composition_dialog.ui:474 src/gui/uifiles/siril.ui:1187
#: src/compositing/align_rgb.c:46
msgid "Image pattern alignment (planetary/deep-sky)"
msgstr "Alinhamento de padrão de imagem (planetário/céu profundo)"

#: src/gui/uifiles/composition_dialog.ui:475 src/gui/uifiles/siril.ui:1178
#: src/compositing/align_rgb.c:44
msgid "One star registration (deep-sky)"
msgstr "Registo de uma estrela (céu profundo)"

#: src/gui/uifiles/composition_dialog.ui:488
msgid ""
"Select framing method for deep-sky alignment:\n"
"First channel - frame to the first channel (always L in luminance mode);\n"
"Min - frame to the minimum overlap of all aligned images;\n"
"COG - frame to the centre of gravity of the pixels in the set of aligned "
"images."
msgstr ""
"Selecione o método de enquadramento para alinhamento de céu profundo:\n"
"Primeiro canal - quadro para o primeiro canal (sempre L no modo de "
"luminância);\n"
"Mín - quadro para a sobreposição mínima de todas as imagens alinhadas;\n"
"COG - quadro para o centro de gravidade dos pixels no conjunto de imagens "
"alinhadas."

#: src/gui/uifiles/composition_dialog.ui:494
msgid "First channel"
msgstr "Primeiro canal"

#: src/gui/uifiles/composition_dialog.ui:495
