msgstr "Fechar a janela atual"

#: src/gui/uifiles/cosmetic_dialog.ui:89
msgid "Apply Cosmetic Correction"
msgstr "Aplicar Correção Cosmetica"

#: src/gui/uifiles/cosmetic_dialog.ui:121 src/gui/uifiles/siril.ui:5363
msgid "Cold Sigma:"
msgstr "Sigma Frio:"

#: src/gui/uifiles/cosmetic_dialog.ui:125
msgid ""
"How many times (in averrage deviation units) a pixel value must differ from "
"the value of surrounding neighbors to be considered as a cold pixel."
msgstr ""
"Quantas vezes (em unidades de desvio médio) o valor de um pi­xel tem de "
"variar relativamente aos valores dos que o rodeiam para ser considerado um "
"pixel frio."

#: src/gui/uifiles/cosmetic_dialog.ui:141
#: src/gui/uifiles/cosmetic_dialog.ui:171
msgid ""
"How many times (in average deviation units) a pixel value must differ from "
"the value of surrounding neighbors to be considered as a cold pixel."
msgstr ""
"Quantas vezes (em unidades de desvio médio) um valor de pixel deve diferir "
"do valor dos vizinhos ao redor para ser considerado um pixel frio."

#: src/gui/uifiles/cosmetic_dialog.ui:187 src/gui/uifiles/siril.ui:5393
msgid "Hot Sigma:"
msgstr "Sigma Quente:"

#: src/gui/uifiles/cosmetic_dialog.ui:191
msgid ""
"How many times (in averrage deviation units) a pixel value must differ from "
"the value of surrounding neighbors to be considered as a hot pixel."
msgstr ""
"Quantas vezes (em unidades de desvio médio) o valor de um pixel tem de "
"variar relativamente aos valores dos que o rodeiam para ser considerado um "
"pixel quente."

