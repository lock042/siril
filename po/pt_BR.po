msgstr "Triplo-Perfil (Mono)"

#: src/gui-gtk4/uifiles/cut_dialog.ui:96
msgid ""
"Generates 3 parallel intensity profiles separated by a given number of "
"pixels. Tri-profiles always plot luminance along each profile."
msgstr ""
"Gera 3 perfis de intensidade paralelos, separados por um determinado número "
"de pixels. Os perfis triplos sempre plotam a luminância ao longo de cada "
"perfil."

#: src/gui-gtk4/uifiles/cut_dialog.ui:109
#: src/gui-gtk4/uifiles/mask_thresholds_dialog.ui:86
