msgstr ""
"Grau polinomial do modelo simplificado. Valores menores = mais rígido (grau "
"1 = plano)."

#: src/gui-gtk4/uifiles/background_extraction_dialog.ui:525
#, fuzzy
msgid "Downsample"
msgstr "Redução de desfoque"

#: src/gui-gtk4/uifiles/background_extraction_dialog.ui:526
msgid ""
"Internal working scale factor. Higher = faster but coarser; the background "
