msgstr "Método de interpolação"

#: src/gui-gtk4/uifiles/background_extraction_dialog.ui:381
#, fuzzy
msgid "Scale"
msgstr "Escala:"

#: src/gui-gtk4/uifiles/background_extraction_dialog.ui:382
