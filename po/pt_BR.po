"Insira as coordenadas para os pontos inicial e final do perfil manualmente"

#: src/gui-gtk4/uifiles/cut_dialog.ui:81
msgid "Spectrometric data"
msgstr "Dados espectrométricos"

#: src/gui-gtk4/uifiles/cut_dialog.ui:83
msgid "Enter data relating to profiling along a spectrum"
msgstr "Insira dados relacionados ao perfil ao longo de um espectro"

