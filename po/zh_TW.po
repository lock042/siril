#: src/gui-gtk4/uifiles/settings_window.ui:3673
msgid "Output of RGB composition / PixelMath"
msgstr "輸出 RGB 合成 / PixelMath"

#: src/gui-gtk4/uifiles/settings_window.ui:3684
