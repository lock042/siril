#: src/gui-gtk4/uifiles/settings_window.ui:3473
msgid ""
"Selects which color space to export >8bpp bit depth images to. The ICC color "
"profile will be embedded in the file.\n"
"    Note: if the format does not support ICC profile embedding, images will "
"always be exported as sRGB."
msgstr ""

#: src/gui-gtk4/uifiles/settings_window.ui:3485
