msgid "Row-order preference:"
msgstr "行序設定："

#: src/gui-gtk4/uifiles/settings_window.ui:442
msgid "Header then Top-Down"
msgstr "先讀檔頭，否則由上而下"

#: src/gui-gtk4/uifiles/settings_window.ui:443
