msgstr "將其他色彩特性檔案轉換為工作中的特性檔案？"

#: src/gui-gtk4/uifiles/settings_window.ui:3611
#: src/gui-gtk4/uifiles/settings_window.ui:3662
msgid "Never"
msgstr "從不"

#: src/gui-gtk4/uifiles/settings_window.ui:3612
msgid "Ask every time"
msgstr "每次詢問"

#: src/gui-gtk4/uifiles/settings_window.ui:3613
msgid "Always"
msgstr "總是"

#: src/gui-gtk4/uifiles/settings_window.ui:3618
msgid ""
"This option sets the behaviour if an image is loaded and it already contains "
"an ICC profile."
msgstr "此選項設定載入影像且影像已包含 ICC 色彩特性檔案時的行為。"

#: src/gui-gtk4/uifiles/settings_window.ui:3628
