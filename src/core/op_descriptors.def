/* op_descriptors.def — THE canonical list of every op_descriptor.
 *
 * One OP_DESC(symbol) entry per descriptor, ordered by id.  This single list
 * feeds BOTH the extern declarations (op_descriptors.h) and the registry array
 * (op_descriptor.c) via the X-macro idiom, so the two can never drift.  The
 * descriptor DEFINITIONS still live next to their hooks in the owning modules.
 *
 * To add an operation: add its definition in the owning .c, then add one line
 * here.  Keep this list ordered by id.
 */
OP_DESC(op_desc_addmax)                  /* arith.addmax */
