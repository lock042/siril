                                <child>
                                  <object class="GtkSpinButton" id="spin_bkg_w">
                                    <property name="adjustment">adjustment_bkg_w</property>
                                    <property name="editable">0</property>
                                    <property name="focusable">1</property>
                                    <property name="numeric">1</property>
                                    <property name="tooltip-text" translatable="yes">Width of the background selection</property>
                                    <property name="width-chars">6</property>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">2</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkSpinButton" id="spin_bkg_h">
                                    <property name="adjustment">adjustment_bkg_h</property>
                                    <property name="editable">0</property>
                                    <property name="focusable">1</property>
                                    <property name="numeric">1</property>
