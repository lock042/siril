                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="button_white_selection">
                                    <property name="focusable">1</property>
                                    <property name="halign">center</property>
                                    <property name="label" translatable="yes">Use current selection</property>
                                    <property name="receives-default">1</property>
                                    <property name="tooltip-text" translatable="yes">You should specify a selection that represents an average of suitable white reference.
    If the selection is empty, the whole image will be used as reference.</property>
                                    <property name="valign">center</property>
                                    <signal name="clicked" handler="on_button_white_selection_clicked"/>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkGrid" id="grid41">
                                <child>
                                  <object class="GtkScale" id="lowWhiteColorCalibScale">
                                    <property name="adjustment">lowWhiteColorCalibAdj</property>
                                    <property name="digits">3</property>
                                    <property name="draw-value">1</property>
                                    <property name="focusable">1</property>
                                    <property name="hexpand">1</property>
                                    <property name="round-digits">3</property>
                                    <property name="tooltip-text" translatable="yes">Lower rejection bound for white selection. Pixels below this value are not taken into account. Black pixels are always excluded from computation.</property>
                                    <property name="value-pos">right</property>
                                    <property name="width-request">160</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkScale" id="upWhiteColorCalibScale">
                                    <property name="adjustment">upWhiteColorCalibAdj</property>
                                    <property name="digits">3</property>
                                    <property name="draw-value">1</property>
                                    <property name="focusable">1</property>
                                    <property name="hexpand">1</property>
                                    <property name="round-digits">3</property>
                                    <property name="tooltip-text" translatable="yes">Upper rejection bound for white selection. Pixels above this value are not taken into account. Saturated pixels are always excluded from computation.</property>
                                    <property name="value-pos">right</property>
                                    <property name="width-request">160</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel" id="label69">
                                    <property name="label" translatable="yes">Lower limit: </property>
