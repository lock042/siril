                                    <child>
                                      <object class="GtkSpinButton" id="spin_white_h">
                                        <property name="adjustment">adjustment_white_h</property>
                                        <property name="editable">0</property>
                                        <property name="focusable">1</property>
                                        <property name="numeric">1</property>
                                        <property name="text">0</property>
                                        <property name="tooltip-text" translatable="yes">Height of the white reference selection</property>
                                        <property name="width-chars">6</property>
                                        <layout>
