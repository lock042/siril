<interface>
  <!-- interface-name color_calibration.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkAdjustment" id="adjustment_bkg_h">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_bkg_w">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_bkg_x">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_bkg_y">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_scale_b">
    <property name="page-increment">10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">1</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_scale_g">
    <property name="page-increment">10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">1</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_scale_r">
    <property name="page-increment">10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">1</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_white_h">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">100</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_white_w">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">100</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_white_x">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">100</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_white_y">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">100</property>
  </object>
  <object class="GtkAdjustment" id="lowWhiteColorCalibAdj">
    <property name="page-increment">10</property>
    <property name="step-increment">0.10</property>
    <property name="upper">1</property>
  </object>
  <object class="GtkAdjustment" id="upWhiteColorCalibAdj">
    <property name="page-increment">10</property>
    <property name="step-increment">0.10</property>
    <property name="upper">1</property>
    <property name="value">0.90</property>
  </object>
  <object class="GtkWindow" id="color_calibration">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox" id="dialog-vbox23">
            <property name="margin-bottom">6</property>
            <property name="margin-end">6</property>
            <property name="margin-start">6</property>
            <property name="margin-top">6</property>
            <property name="orientation">vertical</property>
            <property name="spacing">10</property>
            <child>
              <object class="GtkBox" id="box3">
                <property name="orientation">vertical</property>
                <property name="spacing">10</property>
                <child>
                  <object class="GtkFrame" id="frame22">
                    <child>
                      <object class="GtkBox" id="box40">
                        <property name="margin-top">10</property>
                        <property name="orientation">vertical</property>
                        <property name="spacing">5</property>
                        <child>
                          <object class="GtkBox" id="box42">
                            <property name="homogeneous">1</property>
                            <child>
                              <object class="GtkGrid" id="grid26">
                                <property name="column-homogeneous">1</property>
                                <property name="column-spacing">5</property>
                                <property name="row-spacing">5</property>
                                <child>
                                  <object class="GtkSpinButton" id="spin_bkg_x">
                                    <property name="adjustment">adjustment_bkg_x</property>
                                    <property name="climb-rate">1</property>
                                    <property name="editable">0</property>
                                    <property name="focusable">1</property>
                                    <property name="numeric">1</property>
                                    <property name="tooltip-text" translatable="yes">x coordinate of the start of the background selection</property>
                                    <property name="width-chars">6</property>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkSpinButton" id="spin_bkg_y">
                                    <property name="adjustment">adjustment_bkg_y</property>
                                    <property name="editable">0</property>
                                    <property name="focusable">1</property>
                                    <property name="numeric">1</property>
                                    <property name="tooltip-text" translatable="yes">y coordinate of the start of the background selection</property>
                                    <property name="width-chars">6</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
