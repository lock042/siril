<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name mask_thresholds_dialog.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkAdjustment" id="adj_mask_thresh_max_16bit">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">65535</property>
    <property name="value">65535</property>
  </object>
  <object class="GtkAdjustment" id="adj_mask_thresh_max_8bit">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">255</property>
    <property name="value">255</property>
  </object>
  <object class="GtkAdjustment" id="adj_mask_thresh_max_float">
    <property name="page-increment">0.01</property>
    <property name="step-increment">0.001</property>
    <property name="upper">1</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adj_mask_thresh_min_16bit">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">65535</property>
  </object>
  <object class="GtkAdjustment" id="adj_mask_thresh_min_8bit">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">255</property>
  </object>
  <object class="GtkAdjustment" id="adj_mask_thresh_min_float">
    <property name="page-increment">0.01</property>
    <property name="step-increment">0.001</property>
    <property name="upper">1</property>
  </object>
  <object class="GtkAdjustment" id="adj_thresh_feather_16bit">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">65535</property>
  </object>
  <object class="GtkAdjustment" id="adj_thresh_feather_8bit">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">255</property>
  </object>
  <object class="GtkAdjustment" id="adj_thresh_feather_float">
    <property name="page-increment">0.10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">1</property>
  </object>
  <object class="GtkWindow" id="mask_thresholds_dialog">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox">
            <property name="margin-bottom">6</property>
            <property name="margin-end">6</property>
            <property name="margin-start">6</property>
            <property name="margin-top">6</property>
            <property name="orientation">vertical</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkGrid">
                <property name="column-spacing">12</property>
                <property name="row-spacing">8</property>
                <child>
                  <object class="GtkLabel">
                    <property name="halign">end</property>
                    <property name="label" translatable="yes">Intensity feather range:</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">2</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_mask_threshold_range">
                    <property name="adjustment">adj_thresh_feather_float</property>
                    <property name="digits">3</property>
                    <property name="focusable">1</property>
                    <property name="numeric">1</property>
                    <property name="text" translatable="yes">1</property>
                    <property name="tooltip-text" translatable="yes">Feather range in intensity units (0-1 for float masks, 0-255 for 8-bit masks, 0-65535 for 16-bit masks)</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">2</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="halign">start</property>
                    <property name="label" translatable="yes">Minimum</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="halign">start</property>
                    <property name="label" translatable="yes">Maximum</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_mask_threshold_min">
                    <property name="adjustment">adj_mask_thresh_min_float</property>
                    <property name="digits">3</property>
                    <property name="focusable">1</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_mask_threshold_max">
                    <property name="adjustment">adj_mask_thresh_max_float</property>
                    <property name="digits">3</property>
                    <property name="focusable">1</property>
                    <property name="text" translatable="yes">0</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">1</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="halign">end</property>
            <property name="margin-bottom">12</property>
            <property name="margin-end">12</property>
            <property name="margin-start">12</property>
            <property name="margin-top">12</property>
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <property name="valign">center</property>
            <child>
              <object class="GtkButton" id="threshold_mask_close">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Close</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_threshold_mask_close_clicked"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="threshold_mask_apply">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Apply</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_threshold_mask_apply_clicked"/>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <property name="modal">1</property>
    <property name="resizable">0</property>
    <property name="title" translatable="yes">Image Mask Intensity Thresholds</property>
    <signal name="close-request" handler="siril_widget_hide_on_delete"/>
    <signal name="hide" handler="on_threshold_mask_close_clicked"/>
    <signal name="show" handler="on_threshold_mask_show"/>
  </object>
</interface>
