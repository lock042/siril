<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name curves_dialog.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkImage" id="blue">
    <property name="resource">/org/siril/ui/pixmaps/b.svg</property>
  </object>
  <object class="GtkAdjustment" id="curves_adj_zoom">
    <property name="lower">1</property>
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">100</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adj_curve_slider_min">
    <property name="lower">0</property>
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">100</property>
    <property name="value">0</property>
  </object>
  <object class="GtkAdjustment" id="adj_curve_slider_max">
    <property name="lower">0</property>
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">100</property>
    <property name="value">100</property>
  </object>
  <object class="GtkAdjustment" id="adj_curve_slider_feather">
    <property name="lower">0</property>
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">100</property>
    <property name="value">25</property>
  </object>
  <object class="GtkImage" id="green">
    <property name="resource">/org/siril/ui/pixmaps/g.svg</property>
  </object>
  <object class="GtkImage" id="grid">
    <property name="resource">/org/siril/ui/pixmaps/grid.svg</property>
  </object>
  <object class="GtkImage" id="red">
    <property name="resource">/org/siril/ui/pixmaps/r.svg</property>
  </object>
  <object class="GtkWindow" id="curves_dialog">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox">
            <property name="margin-bottom">6</property>
            <property name="margin-end">6</property>
            <property name="margin-start">6</property>
            <property name="margin-top">6</property>
            <property name="orientation">vertical</property>
            <property name="spacing">10</property>
            <child>
              <object class="GtkBox">
                <property name="baseline-position">top</property>
                <property name="hexpand">1</property>
                <property name="spacing">5</property>
                <property name="vexpand">1</property>
                <child>
                  <object class="GtkBox">
                    <property name="baseline-position">top</property>
                    <property name="hexpand">1</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">5</property>
                    <property name="vexpand">1</property>
                    <child>
                      <object class="GtkBox" id="curves_toolbar1">
                        <property name="css-classes">toolbar</property>
                        <property name="valign">end</property>
                        <child>
                          <object class="GtkSpinButton" id="curves_spin_zoom">
                            <property name="adjustment">curves_adj_zoom</property>
                            <property name="focusable">1</property>
                            <property name="numeric">1</property>
                            <property name="text">1</property>
                            <property name="tooltip-text" translatable="yes">Curves histogram display zoom</property>
                            <property name="value">1</property>
                            <signal name="value-changed" handler="on_curves_spin_zoom_value_changed"/>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="curves_reset_zoom">
                            <property name="halign">center</property>
                            <property name="icon-name">zoom-original-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Reset zoom to 1</property>
                            <property name="use-underline">1</property>
                            <property name="valign">center</property>
                            <signal name="clicked" handler="on_curves_reset_zoom_clicked"/>
                          </object>
                        </child>
                        <child>
                          <object class="GtkCheckButton" id="curves_log_check">
                            <property name="focusable">1</property>
                            <property name="halign">end</property>
                            <property name="label" translatable="yes">Logarithmic scale</property>
                            <property name="tooltip-text" translatable="yes">Show the histogram with a logarithmic scale. Does not affect the transfer function display.
                                </property>
                            <signal name="toggled" handler="on_curves_log_check_toggled"/>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkScrolledWindow" id="curves_scroll">
                        <property name="child">
                          <object class="GtkViewport" id="curves_viewport">
                            <property name="child">
                              <object class="GtkDrawingArea" id="curves_drawingarea">
                                <property name="hexpand">1</property>
                                <property name="vexpand">1</property>
                              </object>
                            </property>
                            <property name="hexpand">1</property>
                            <property name="vexpand">1</property>
                          </object>
                        </property>
                        <property name="focusable">1</property>
                        <property name="height-request">300</property>
                        <property name="hexpand">1</property>
                        <property name="hscrollbar-policy">always</property>
                        <property name="overlay-scrolling">0</property>
                        <property name="vexpand">1</property>
                        <property name="vscrollbar-policy">always</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="baseline-position">top</property>
                        <property name="hexpand">1</property>
                        <property name="spacing">5</property>
                        <property name="vexpand">0</property>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">6</property>
                            <property name="valign">start</property>
                            <child>
                              <object class="GtkGrid" id="curves_channel_box">
                                <property name="column-homogeneous">1</property>
                                <property name="column-spacing">6</property>
                                <property name="row-spacing">6</property>
                                <child>
                                  <object class="GtkToggleButton" id="curves_chan_rgb">
                                    <property name="active">1</property>
                                    <property name="label" translatable="yes">RGB/K</property>
                                    <property name="tooltip-text" translatable="yes">Master channel (RGB or greyscale)</property>
                                    <signal name="toggled" handler="on_curves_chan_rgb_toggled"/>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="curves_chan_r">
                                    <property name="label" translatable="yes">R</property>
                                    <property name="tooltip-text" translatable="yes">Red channel</property>
                                    <property name="group">curves_chan_rgb</property>
                                    <signal name="toggled" handler="on_curves_chan_r_toggled"/>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="curves_chan_g">
                                    <property name="label" translatable="yes">G</property>
                                    <property name="tooltip-text" translatable="yes">Green channel</property>
                                    <property name="group">curves_chan_rgb</property>
                                    <signal name="toggled" handler="on_curves_chan_g_toggled"/>
                                    <layout>
                                      <property name="column">2</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="curves_chan_b">
                                    <property name="label" translatable="yes">B</property>
                                    <property name="tooltip-text" translatable="yes">Blue channel</property>
                                    <property name="group">curves_chan_rgb</property>
                                    <signal name="toggled" handler="on_curves_chan_b_toggled"/>
                                    <layout>
                                      <property name="column">3</property>
                                      <property name="row">0</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="curves_chan_l">
                                    <property name="label" translatable="yes">L</property>
                                    <property name="tooltip-text" translatable="yes">Luminance (CIE L*)</property>
                                    <property name="group">curves_chan_rgb</property>
                                    <signal name="toggled" handler="on_curves_chan_l_toggled"/>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="curves_chan_c">
                                    <property name="label" translatable="yes">C</property>
                                    <property name="tooltip-text" translatable="yes">Chrominance (LCH chroma)</property>
                                    <property name="group">curves_chan_rgb</property>
                                    <signal name="toggled" handler="on_curves_chan_c_toggled"/>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="curves_chan_s">
                                    <property name="label" translatable="yes">S</property>
                                    <property name="tooltip-text" translatable="yes">Saturation (HSV)</property>
                                    <property name="group">curves_chan_rgb</property>
                                    <signal name="toggled" handler="on_curves_chan_s_toggled"/>
                                    <layout>
                                      <property name="column">2</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox" id="curves_toolbar2">
                                <property name="css-classes">toolbar</property>
                                <property name="valign">start</property>
                                <child>
                                  <object class="GtkToggleButton" id="curves_grid_toggle">
                                    <property name="active">1</property>
                                    <property name="halign">center</property>
                                    <property name="tooltip-text" translatable="yes">Toggles whether the grid is shown on the histogram display</property>
                                    <property name="valign">center</property>
                                    <property name="child">
                                      <object class="GtkImage">
                                        <property name="resource">/org/siril/ui/pixmaps/grid.svg</property>
                                      </object>
                                    </property>
                                    <signal name="toggled" handler="on_curves_display_toggle"/>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkToggleButton" id="curves_pipette_button">
                                    <property name="halign">center</property>
                                    <property name="icon-name">color-select-symbolic</property>
                                    <property name="tooltip-text" translatable="yes">Pipette: click on the image to mark the corresponding value on the curve</property>
                                    <property name="valign">center</property>
                                    <signal name="toggled" handler="on_curves_pipette_button_toggled"/>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkDropDown" id="curves_interpolation_combo">
                            <property name="halign">center</property>
                            <property name="hexpand">1</property>
                            <property name="model">
                              <object class="GtkStringList">
                                <items>
                                  <item translatable="yes">Cubic Spline</item>
                                  <item translatable="yes">Linear</item>
                                  <item translatable="yes">Akima Spline</item>
                                </items>
                              </object>
                            </property>
                            <property name="selected">2</property>
                            <property name="tooltip-text" translatable="yes">Interpolation algorithm used to compute a curve from the placed points</property>
                            <property name="valign">center</property>
                            <signal name="notify::selected" handler="on_curves_interpolation_combo_changed"/>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="curves_stage_box">
                        <property name="spacing">6</property>
                        <property name="valign">start</property>
                        <child>
                          <object class="GtkButton" id="curves_undo_stage_button">
                            <property name="label" translatable="yes">↩ Stage</property>
                            <property name="sensitive">0</property>
                            <property name="tooltip-text" translatable="yes">Undo the last applied stage</property>
                            <signal name="clicked" handler="on_curves_undo_stage_clicked"/>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="curves_apply_stage_button">
                            <property name="label" translatable="yes">Apply Stage</property>
                            <property name="tooltip-text" translatable="yes">Commit current curves as a non-destructive stage. Use Apply to validate all stages as one undo entry.</property>
                            <signal name="clicked" handler="on_curves_apply_stage_clicked"/>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">6</property>
                        <child>
                          <object class="GtkCheckButton" id="curve_check_range_button">
                            <property name="focusable">1</property>
                            <property name="halign">start</property>
                            <property name="label" translatable="yes">Enable Range Masking</property>
                            <property name="tooltip-text" translatable="yes">Restrict the curve to a luminance range with a soft feathered roll-off</property>
                            <signal name="toggled" handler="on_curve_check_range_button_toggled"/>
                          </object>
                        </child>
                        <child>
                          <object class="GtkExpander" id="curve_range_expander">
                            <property name="label" translatable="yes">Range</property>
                            <property name="sensitive">0</property>
                            <property name="child">
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">3</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">Min</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkScale" id="curve_slider_min">
                                    <property name="adjustment">adj_curve_slider_min</property>
                                    <property name="digits">3</property>
                                    <property name="draw-value">0</property>
                                    <property name="hexpand">1</property>
                                    <property name="tooltip-text" translatable="yes">Minimum luminance range.</property>
                                    <signal name="value-changed" handler="on_curves_range_value_changed"/>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">Max</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkScale" id="curve_slider_max">
                                    <property name="adjustment">adj_curve_slider_max</property>
                                    <property name="digits">3</property>
                                    <property name="draw-value">0</property>
                                    <property name="hexpand">1</property>
                                    <property name="tooltip-text" translatable="yes">Maximum luminance range.</property>
                                    <signal name="value-changed" handler="on_curves_range_value_changed"/>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="yes">Feather</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkScale" id="curve_slider_feather">
                                    <property name="adjustment">adj_curve_slider_feather</property>
                                    <property name="digits">3</property>
                                    <property name="draw-value">0</property>
                                    <property name="hexpand">1</property>
                                    <property name="tooltip-text" translatable="yes">Soft roll-off width at range boundaries.</property>
                                    <signal name="value-changed" handler="on_curves_feather_value_changed"/>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <child>
                          <object class="GtkGrid" id="curves_point_grid">
                            <property name="column-spacing">10</property>
                            <property name="hexpand">1</property>
                            <property name="valign">start</property>
                            <child>
                              <object class="GtkLabel" id="curves_label_y">
                                <property name="halign">start</property>
                                <property name="label" translatable="yes">Curve point Y: </property>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="row">2</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="curves_label_id">
                                <property name="halign">start</property>
                                <property name="label" translatable="yes">Curve point ID: </property>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="row">0</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="curves_label_x">
                                <property name="halign">start</property>
                                <property name="label" translatable="yes">Curve point X: </property>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="row">1</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox">
                                <property name="baseline-position">top</property>
                                <property name="hexpand">0</property>
                                <property name="spacing">5</property>
                                <property name="vexpand">0</property>
                                <child>
                                  <object class="GtkBox" id="curves_prev_event_box">
                                    <property name="visible">True</property>
                                    <child>
                                      <object class="GtkImage" id="curves_prev_button">
                                        <property name="halign">center</property>
                                        <property name="hexpand">0</property>
                                        <property name="resource">/org/siril/ui/pixmaps/arrow_left.svg</property>
                                        <property name="valign">center</property>
                                        <property name="vexpand">0</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkEntry" id="curves_id_entry">
                                    <property name="focusable">1</property>
                                    <property name="has-frame">0</property>
                                    <property name="hexpand">0</property>
                                    <property name="input-purpose">number</property>
                                    <property name="max-length">2</property>
                                    <property name="text">0</property>
                                    <property name="tooltip-text" translatable="yes">The ID of the selected curve point</property>
                                    <property name="width-chars">2</property>
                                    <property name="xalign">0.5</property>
                                    <signal name="activate" handler="on_curves_id_entry_activate"/>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox" id="curves_next_event_box">
                                    <property name="visible">True</property>
                                    <child>
                                      <object class="GtkImage" id="curves_next_button">
                                        <property name="halign">center</property>
                                        <property name="hexpand">0</property>
                                        <property name="resource">/org/siril/ui/pixmaps/arrow_right.svg</property>
                                        <property name="valign">center</property>
                                        <property name="vexpand">0</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <layout>
                                  <property name="column">1</property>
                                  <property name="row">0</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkEntry" id="curves_x_entry">
                                <property name="focusable">1</property>
                                <property name="has-frame">0</property>
                                <property name="hexpand">1</property>
                                <property name="input-purpose">number</property>
                                <property name="text">0.0000000</property>
                                <property name="tooltip-text" translatable="yes">X coordinate of the selected curve point</property>
                                <property name="width-chars">10</property>
                                <signal name="activate" handler="on_curves_x_entry_activate"/>
                                <layout>
                                  <property name="column">1</property>
                                  <property name="row">1</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkEntry" id="curves_y_entry">
                                <property name="focusable">1</property>
                                <property name="has-frame">0</property>
                                <property name="hexpand">1</property>
                                <property name="input-purpose">number</property>
                                <property name="text">1.0000000</property>
                                <property name="tooltip-text" translatable="yes">Y coordinate of the selected curve point</property>
                                <property name="width-chars">10</property>
                                <signal name="activate" handler="on_curves_y_entry_activate"/>
                                <layout>
                                  <property name="column">1</property>
                                  <property name="row">2</property>
                                </layout>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox" id="curves_clip_box">
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkLabel" id="curves_clip_label">
                                <property name="halign">center</property>
                                <property name="label" translatable="yes">Clip (%)</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkEntry" id="curves_clip_low">
                                <property name="editable">0</property>
                                <property name="focusable">1</property>
                                <property name="halign">center</property>
                                <property name="has-frame">0</property>
                                <property name="max-width-chars">8</property>
                                <property name="sensitive">0</property>
                                <property name="tooltip-text" translatable="yes">Clipped pixels count (shadows)</property>
                                <property name="width-chars">6</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkEntry" id="curves_clip_high">
                                <property name="editable">0</property>
                                <property name="focusable">1</property>
                                <property name="halign">center</property>
                                <property name="has-frame">0</property>
                                <property name="max-width-chars">8</property>
                                <property name="sensitive">0</property>
                                <property name="tooltip-text" translatable="yes">Clipped pixels count (highlights)</property>
                                <property name="width-chars">6</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="spacing">5</property>
                        <property name="valign">start</property>
                        <child>
                          <object class="GtkCheckButton" id="curves_sequence_check">
                            <property name="focusable">1</property>
                            <property name="halign">start</property>
                            <property name="label" translatable="yes">Apply to sequence</property>
                            <property name="tooltip-text" translatable="yes">If a sequence is loaded and this is activated, perform the processing on all images of the sequence instead of only the loaded image.</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="curves_seq_prefix_label">
                            <property name="halign">start</property>
                            <property name="label" translatable="yes">Output prefix:</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkEntry" id="curves_seq_entry">
                            <property name="focusable">1</property>
                            <property name="input-hints">no-emoji|none</property>
                            <property name="max-length">10</property>
                            <property name="text">curve_</property>
                            <property name="tooltip-text" translatable="yes">Prefix of the image names resulting from the curve transformation</property>
                            <property name="width-chars">10</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="curves_preview_check">
                        <property name="active">1</property>
                        <property name="focusable">1</property>
                        <property name="halign">start</property>
                        <property name="label" translatable="yes">Preview</property>
                        <property name="tooltip-text" translatable="yes">Toggles preview</property>
                        <signal name="toggled" handler="on_curves_preview_toggled"/>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="halign">end</property>
            <property name="margin-bottom">12</property>
            <property name="margin-end">12</property>
            <property name="margin-start">12</property>
            <property name="margin-top">12</property>
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <property name="valign">center</property>
            <child>
              <object class="GtkButton" id="curves_reset_button">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Reset</property>
                <property name="receives-default">1</property>
                <property name="tooltip-text" translatable="yes">Reset curves transformation dialog window</property>
                <property name="valign">start</property>
                <signal name="clicked" handler="on_curves_reset_button_clicked"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="curves_close_button">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Close</property>
                <property name="receives-default">1</property>
                <property name="tooltip-text" translatable="yes">Close curves transformation dialog window</property>
                <property name="valign">start</property>
                <signal name="clicked" handler="on_curves_close_button_clicked"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="curves_apply_button">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Apply</property>
                <property name="receives-default">1</property>
                <property name="tooltip-text" translatable="yes">Apply curves transformation</property>
                <property name="valign">start</property>
                <signal name="clicked" handler="on_curves_apply_button_clicked"/>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <property name="default-height">1</property>
    <property name="default-width">1</property>
    <property name="height-request">715</property>
    <property name="title" translatable="yes">Curves Transformation</property>
    <property name="width-request">420</property>
    <signal name="close-request" handler="siril_widget_hide_on_delete"/>
    <signal name="hide" handler="on_curves_close_button_clicked"/>
    <signal name="show" handler="on_curves_window_show"/>
  </object>
</interface>
