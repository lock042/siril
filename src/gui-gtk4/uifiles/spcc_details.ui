<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name spcc_details.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkWindow" id="spcc_details">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox">
            <property name="margin-bottom">6</property>
            <property name="margin-end">6</property>
            <property name="margin-start">6</property>
            <property name="margin-top">6</property>
            <property name="orientation">vertical</property>
            <property name="spacing">2</property>
            <child>
              <object class="GtkFrame">
                <property name="valign">center</property>
                <child>
                  <object class="GtkGrid" id="spcc_details_ver">
                    <property name="column-spacing">6</property>
                    <property name="row-spacing">6</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">start</property>
                        <property name="label" translatable="yes">Name</property>
                        <property name="valign">start</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">start</property>
                        <property name="label" translatable="yes">Manufacturer</property>
                        <property name="valign">start</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="spcc_details_name">
                        <property name="halign">start</property>
                        <property name="label">label</property>
                        <property name="max-width-chars">40</property>
                        <property name="wrap">1</property>
                        <property name="wrap-mode">word-char</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="spcc_details_mfr">
                        <property name="halign">start</property>
                        <property name="label">label</property>
                        <property name="max-width-chars">40</property>
                        <property name="wrap">1</property>
                        <property name="wrap-mode">word-char</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="spcc_details_source">
                        <property name="halign">start</property>
                        <property name="label">label</property>
                        <property name="max-width-chars">40</property>
                        <property name="wrap">1</property>
                        <property name="wrap-mode">word-char</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">3</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">start</property>
                        <property name="label" translatable="yes">Data Source</property>
                        <property name="valign">start</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">3</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">start</property>
                        <property name="label" translatable="yes">Datafile version</property>
                        <property name="valign">start</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">2</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="spcc_details_version">
                        <property name="halign">start</property>
                        <property name="label">label</property>
                        <property name="max-width-chars">40</property>
                        <property name="wrap">1</property>
                        <property name="wrap-mode">word-char</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">2</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">start</property>
                        <property name="label" translatable="yes">Number of samples</property>
                        <property name="valign">start</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">5</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="spcc_details_nsamples">
                        <property name="halign">start</property>
                        <property name="label">label</property>
                        <property name="max-width-chars">40</property>
                        <property name="wrap">1</property>
                        <property name="wrap-mode">word-char</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">5</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="spcc_details_comment_label">
                        <property name="halign">start</property>
                        <property name="label" translatable="yes">Comment</property>
                        <property name="valign">start</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">4</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="spcc_details_comment">
                        <property name="halign">start</property>
                        <property name="label">label</property>
                        <property name="max-width-chars">40</property>
                        <property name="wrap">1</property>
                        <property name="wrap-mode">word-char</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">4</property>
                        </layout>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="label">
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">SPCC Details</property>
                    <attributes>
                      <attribute name="weight" value="bold"/>
                    </attributes>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="halign">end</property>
            <property name="margin-bottom">12</property>
            <property name="margin-end">12</property>
            <property name="margin-start">12</property>
            <property name="margin-top">12</property>
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <property name="valign">center</property>
            <child>
              <object class="GtkButton" id="spcc_details_plot">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Plot</property>
                <property name="receives-default">1</property>
                <property name="tooltip-text" translatable="yes">Plot the data (QE, transmittance or relative photon count) as a function of wavelength</property>
                <signal name="clicked" handler="on_spcc_details_plot_clicked"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="spcc_details_close">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Close</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_spcc_details_close_clicked"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <property name="default-width">320</property>
    <property name="resizable">0</property>
    <property name="title" translatable="yes">SPCC Details</property>
    <property name="width-request">320</property>
    <signal name="close-request" handler="siril_widget_hide_on_delete"/>
  </object>
</interface>
