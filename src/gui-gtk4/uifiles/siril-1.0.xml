<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE cambalache-catalog SYSTEM "cambalache-catalog.dtd">
<!-- Cambalache catalog for Siril's custom GTK4 widgets.
     Generated by hand: Siril ships no GObject-Introspection typelib, so the
     usual cmb-catalog-gen (GIR -> catalog) route is not available.

     Install so Cambalache can discover it:
         cp siril-1.0.xml ~/.cambalache/catalogs/
     (or any $XDG_DATA_DIRS/cambalache/catalogs/ directory)

     The project file (siril.cmb) enables this catalog via depends="siril-1.0".

     Each child element is named after a Cambalache DB table; its text is a
     comma-separated list of Python tuples inserted positionally into that
     table. The "type" columns are, in order:
         type_id, parent_id, library_id, version, deprecated_version,
         abstract, derivable, layout, category, workspace_type
     workspace_type is set to GtkDrawingArea so the canvas can render a
     placeholder without needing a Siril runtime library. -->
<cambalache-catalog name="siril" version="1.0" namespace="Siril" prefix="siril" targets="1.0" depends="gtk-4.0">
  <type>
    ('SirilImageView', 'GtkWidget', 'siril', None, None, False, False, None, 'display', 'GtkDrawingArea')
  </type>
</cambalache-catalog>
