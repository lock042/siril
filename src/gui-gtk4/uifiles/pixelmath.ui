<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name pixelmath.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkAdjustment" id="adj_pm_high">
    <property name="page-increment">0.10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">1</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adj_pm_low">
    <property name="page-increment">0.10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">1</property>
  </object>
  <object class="GtkApplicationWindow" id="pixel_math_dialog">
    <property name="resizable">0</property>
    <property name="title" translatable="yes">Sequence List</property>
    <property name="width-request">800</property>
    <signal name="close-request" handler="siril_widget_hide_on_delete"/>
    <signal name="show" handler="on_pixel_math_dialog_show"/>
    <child>
      <object class="GtkBox">
        <property name="margin-bottom">6</property>
        <property name="margin-end">6</property>
        <property name="margin-start">6</property>
        <property name="margin-top">6</property>
        <property name="orientation">vertical</property>
        <property name="spacing">5</property>
        <child>
          <object class="GtkFrame">
            <property name="child">
              <object class="GtkBox">
                <property name="spacing">5</property>
                <child>
                  <object class="GtkEntry" id="pixel_math_entry_r">
                    <property name="focusable">1</property>
                    <property name="hexpand">1</property>
                    <property name="input-hints">no-emoji|none</property>
                    <property name="margin-top">5</property>
                    <signal name="activate" handler="on_pixel_math_entry_activate"/>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="pm_expr1_bt">
                    <property name="focusable">1</property>
                    <property name="receives-default">1</property>
                    <property name="tooltip-text" translatable="yes">Save expression in presets</property>
                    <signal name="clicked" handler="on_pm_expr1_bt_clicked"/>
                    <child>
                      <object class="GtkImage">
                        <property name="icon-name">document-save-symbolic</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
            <child type="label">
              <object class="GtkLabel" id="label_RGBK">
                <property name="label" translatable="yes">RGB/K</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkFrame">
            <property name="child">
              <object class="GtkBox">
                <property name="spacing">5</property>
                <child>
                  <object class="GtkEntry" id="pixel_math_entry_g">
                    <property name="focusable">1</property>
                    <property name="hexpand">1</property>
                    <property name="input-hints">no-emoji|none</property>
                    <property name="margin-top">5</property>
                    <property name="sensitive">0</property>
                    <signal name="activate" handler="on_pixel_math_entry_activate"/>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="pm_expr2_bt">
                    <property name="focusable">1</property>
                    <property name="receives-default">1</property>
                    <property name="tooltip-text" translatable="yes">Save expression in presets</property>
                    <signal name="clicked" handler="on_pm_expr2_bt_clicked"/>
                    <child>
                      <object class="GtkImage">
                        <property name="icon-name">document-save-symbolic</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
            <child type="label">
              <object class="GtkLabel">
                <property name="label" translatable="yes">G</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkFrame">
            <property name="child">
              <object class="GtkBox">
                <property name="spacing">5</property>
                <child>
                  <object class="GtkEntry" id="pixel_math_entry_b">
                    <property name="focusable">1</property>
                    <property name="hexpand">1</property>
                    <property name="input-hints">no-emoji|none</property>
                    <property name="margin-top">5</property>
                    <property name="sensitive">0</property>
                    <signal name="activate" handler="on_pixel_math_entry_activate"/>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="pm_expr3_bt">
                    <property name="focusable">1</property>
                    <property name="receives-default">1</property>
                    <property name="tooltip-text" translatable="yes">Save expression in presets</property>
                    <signal name="clicked" handler="on_pm_expr3_bt_clicked"/>
                    <child>
                      <object class="GtkImage">
                        <property name="icon-name">document-save-symbolic</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
            <child type="label">
              <object class="GtkLabel">
                <property name="label" translatable="yes">B</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <child>
              <object class="GtkLabel" id="pixel_math_status">
                <property name="halign">start</property>
                <property name="hexpand">1</property>
                <style>
                  <class name="label-info"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="pm_use_rgb_button">
                <property name="active">1</property>
                <property name="focusable">1</property>
                <property name="halign">end</property>
                <property name="label" translatable="yes">Use single RGB/K expression</property>
                <property name="tooltip-text" translatable="yes">Unchecking this option will give you an RGB image where each output channel is expressed by a formula.</property>
                <signal name="toggled" handler="on_pm_use_rgb_button_toggled"/>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkFrame">
            <property name="child">
              <object class="GtkBox">
                <property name="margin-top">5</property>
                <child>
                  <object class="GtkScrolledWindow" id="pixel_math_scrolled_variables">
                    <property name="focusable">1</property>
                    <property name="hexpand">1</property>
                  </object>
                </child>
                <child>
                  <object class="GtkScrolledWindow" id="pixel_math_scrolled_functions">
                    <property name="focusable">1</property>
                  </object>
                </child>
                <child>
                  <object class="GtkScrolledWindow" id="pixel_math_scrolled_operators">
                    <property name="focusable">1</property>
                  </object>
                </child>
              </object>
            </property>
            <property name="height-request">200</property>
            <property name="vexpand">1</property>
            <child type="label">
              <object class="GtkLabel">
                <property name="label" translatable="yes">Images</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="pixel_math_status2">
            <property name="halign">end</property>
          </object>
        </child>
        <child>
          <object class="GtkFrame">
            <property name="child">
              <object class="GtkEntry" id="pixel_math_entry_param">
                <property name="focusable">1</property>
                <property name="input-hints">no-emoji|none</property>
                <property name="margin-top">5</property>
                <property name="tooltip-markup" translatable="yes">Comma separated value parameters. The parameter thus defined can be used in the expressions.
For example, if you set parameters with the expression &lt;i&gt;factor=0.8, K=0.2,&lt;/i&gt;, all the occurences of &lt;i&gt;factor&lt;/i&gt; and &lt;i&gt;K&lt;/i&gt; in the formula above will be replaced by 0.8 and 0.2 respectively.

&lt;i&gt;Ha * factor + OIII * K&lt;/i&gt; would therefore evaluate to &lt;i&gt;Ha * 0.8 + OIII * 0.2&lt;/i&gt;</property>
                <signal name="activate" handler="on_pixel_math_entry_activate"/>
              </object>
            </property>
            <child type="label">
              <object class="GtkLabel">
                <property name="label" translatable="yes">Parameters</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkExpander">
            <property name="focusable">1</property>
            <child>
              <object class="GtkBox">
                <property name="margin-top">5</property>
                <property name="orientation">vertical</property>
                <property name="spacing">5</property>
                <child>
                  <object class="GtkCheckButton" id="rescale_pm_button">
                    <property name="focusable">1</property>
                    <property name="label" translatable="yes">Rescale result</property>
                    <property name="tooltip-text" translatable="yes">Check this option to rescale the pixel values of the resulting image to the specified output range (see the lower range and upper range parameters below)</property>
                    <signal name="toggled" handler="on_rescale_pm_button_toggled"/>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_pm_low">
                    <property name="adjustment">adj_pm_low</property>
                    <property name="digits">8</property>
                    <property name="focusable">1</property>
                    <property name="halign">end</property>
                    <property name="numeric">1</property>
                    <property name="sensitive">0</property>
                    <property name="tooltip-text" translatable="yes">When the rescale option is enabled, this is the lower bound of the output rescaling range.</property>
                    <property name="width-chars">12</property>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_pm_high">
                    <property name="adjustment">adj_pm_high</property>
                    <property name="digits">8</property>
                    <property name="focusable">1</property>
                    <property name="halign">end</property>
                    <property name="numeric">1</property>
                    <property name="sensitive">0</property>
                    <property name="tooltip-text" translatable="yes">When the rescale option is enabled, this is the upper bound of the output rescaling range.</property>
                    <property name="value">1</property>
                    <property name="width-chars">12</property>
                  </object>
                </child>
                <child>
                  <object class="GtkCheckButton" id="cumulate_pm_button">
                    <property name="active">1</property>
                    <property name="focusable">1</property>
                    <property name="label" translatable="yes">Sum exposure time</property>
                    <property name="tooltip-text" translatable="yes">Sum of the exposure times of the different images used for the composition. This will change the value of some keywords such as STACKCNT (number of frames stacked) and LIVETIME (total exposure).</property>
                  </object>
                </child>
              </object>
            </child>
            <child type="label">
              <object class="GtkLabel">
                <property name="label" translatable="yes">Output</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkExpander">
            <property name="focusable">1</property>
            <child>
              <object class="GtkScrolledWindow" id="pixel_math_scrolled_presets">
                <property name="focusable">1</property>
                <property name="height-request">100</property>
                <property name="tooltip-text" translatable="yes">Preset list. You can delete an item or the entire list by selecting what you want and pressing the delete key.</property>
              </object>
            </child>
            <child type="label">
              <object class="GtkLabel">
                <property name="label" translatable="yes">Presets</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="halign">end</property>
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <property name="visible">True</property>
            <child>
              <object class="GtkButton" id="close_pixel_math">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Close</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_close_pixel_math_clicked"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="apply_pixel_math">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Apply</property>
                <property name="receives-default">1</property>
                <property name="tooltip-text" translatable="yes">Apply formula in the text area</property>
                <signal name="clicked" handler="on_apply_pixel_math_clicked"/>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child type="titlebar">
      <object class="GtkHeaderBar" id="pixel_math_header">
        <child type="end">
          <object class="GtkBox" id="pixel_math_buttonbar">
            <property name="halign">end</property>
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <property name="visible">True</property>
            <child>
              <object class="GtkButton" id="pixel_math_add_var_button">
                <property name="focusable">1</property>
                <property name="receives-default">1</property>
                <property name="tooltip-text" translatable="yes">Add an image as a variable</property>
                <signal name="clicked" handler="on_pixel_math_add_var_button_clicked"/>
                <child>
                  <object class="GtkImage">
                    <property name="icon-name">list-add-symbolic</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="pixel_math_remove_var_button">
                <property name="focusable">1</property>
                <property name="receives-default">1</property>
                <property name="tooltip-text" translatable="yes">Remove selected image</property>
                <signal name="clicked" handler="on_pixel_math_remove_var_button_clicked"/>
                <child>
                  <object class="GtkImage">
                    <property name="icon-name">list-remove-symbolic</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
