<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name mask_from_stars.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkAdjustment" id="adj_mask_feather">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">100</property>
  </object>
  <object class="GtkAdjustment" id="adj_mask_star_radius">
    <property name="lower">0.5</property>
    <property name="page-increment">1</property>
    <property name="step-increment">0.10</property>
    <property name="upper">20</property>
    <property name="value">4</property>
  </object>
  <object class="GtkWindow" id="mask_from_stars_dialog">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox">
            <property name="margin-bottom">6</property>
            <property name="margin-end">6</property>
            <property name="margin-start">6</property>
            <property name="margin-top">6</property>
            <property name="orientation">vertical</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkBox">
                <property name="margin-bottom">6</property>
                <property name="margin-end">6</property>
                <property name="margin-start">6</property>
                <property name="margin-top">6</property>
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <child>
                  <object class="GtkGrid">
                    <property name="column-spacing">12</property>
                    <property name="row-spacing">8</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">end</property>
                        <property name="label" translatable="yes">Star radius (FWHM):</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSpinButton" id="spin_mask_star_radius">
                        <property name="adjustment">adj_mask_star_radius</property>
                        <property name="digits">1</property>
                        <property name="focusable">1</property>
                        <property name="numeric">1</property>
                        <property name="tooltip-text" translatable="yes">Star radius as a multiple of FWHM</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">end</property>
                        <property name="label" translatable="yes">Output bit depth:</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkDropDown" id="combo_mask_from_stars_bitdepth">
                        <property name="model">
                          <object class="GtkStringList">
                            <items>
                              <item translatable="yes">8-bit</item>
                              <item translatable="yes">16-bit</item>
                              <item translatable="yes">32-bit</item>
                            </items>
                          </object>
                        </property>
                        <property name="selected">1</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">end</property>
                        <property name="label" translatable="yes">Feather radius:</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">2</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSpinButton" id="spin_mask_feather">
                        <property name="adjustment">adj_mask_feather</property>
                        <property name="focusable">1</property>
                        <property name="numeric">1</property>
                        <property name="tooltip-text" translatable="yes">Feather radius in pixels (0 = no feathering)</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">2</property>
                        </layout>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkSeparator"/>
                </child>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">start</property>
                        <property name="label" translatable="yes">Options:</property>
                        <attributes>
                          <attribute name="weight" value="bold"/>
                        </attributes>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="toggle_mask_stars_invert">
                        <property name="focusable">1</property>
                        <property name="label" translatable="yes">Invert mask</property>
                        <property name="tooltip-text" translatable="yes">Invert the mask after creation</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="halign">end</property>
            <property name="margin-bottom">12</property>
            <property name="margin-end">12</property>
            <property name="margin-start">12</property>
            <property name="margin-top">12</property>
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <property name="valign">center</property>
            <child>
              <object class="GtkButton" id="mask_from_stars_close">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Close</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_mask_from_stars_close_clicked"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="mask_from_stars_apply">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Apply</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_mask_from_stars_apply_clicked"/>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <property name="modal">1</property>
    <property name="resizable">0</property>
    <property name="title" translatable="yes">Create Mask from Stars</property>
    <signal name="close-request" handler="siril_widget_hide_on_delete"/>
    <signal name="hide" handler="on_mask_from_stars_close_clicked"/>
    <signal name="show" handler="on_mask_from_stars_dialog_show"/>
  </object>
</interface>
