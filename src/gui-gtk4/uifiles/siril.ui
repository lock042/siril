                                                        <child>
                                                          <object class="GtkEntry" id="startIndiceEntry">
                                                            <property name="focusable">1</property>
                                                            <property name="tooltip-text" translatable="1">Indicates the start indice of your converted files. This value must be included in the [1, 65535] range.</property>
