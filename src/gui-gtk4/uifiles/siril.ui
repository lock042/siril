<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name siril.ui -->
  <requires lib="gtk" version="4.0"/>
  <requires lib="SirilImageView" version="1.0"/>
  <object class="GtkAdjustment" id="adjCPU">
    <property name="lower">1</property>
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">1024</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adj_driz_scale">
    <property name="lower">0.10</property>
    <property name="page-increment">0.10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">10</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adj_highlights">
    <property name="page-increment">10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">1</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adj_iter_deconvolution">
    <property name="lower">1</property>
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">1000</property>
    <property name="value">10</property>
  </object>
  <object class="GtkAdjustment" id="adj_midtones">
    <property name="page-increment">1</property>
    <property name="step-increment">0.01</property>
    <property name="upper">1</property>
    <property name="value">0.5</property>
  </object>
  <object class="GtkAdjustment" id="adj_shadows">
    <property name="page-increment">10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment-finalstretch">
    <property name="page-increment">0.10</property>
    <property name="step-increment">0.05</property>
    <property name="upper">4</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_blue">
    <property name="page-increment">10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">10</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_brightness">
    <property name="page-increment">10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">10</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_colormap_angle">
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">359</property>
    <property name="value">300</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_edinit">
    <property name="lower">0.001</property>
    <property name="page-increment">0.001</property>
    <property name="step-increment">0.001</property>
    <property name="upper">1</property>
    <property name="value">0.025</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_height_console">
    <property name="lower">90</property>
    <property name="page-increment">10</property>
    <property name="step-increment">10</property>
    <property name="upper">130</property>
    <property name="value">90</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_red">
    <property name="page-increment">10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">10</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_remix_master">
    <property name="page-increment">0.10</property>
    <property name="step-increment">0.05</property>
    <property name="upper">1</property>
    <property name="value">0.5</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_stack_filter">
    <property name="lower">1</property>
    <property name="page-increment">10</property>
    <property name="step-increment">1</property>
    <property name="upper">99</property>
    <property name="value">90</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_treshold">
    <property name="page-increment">10</property>
    <property name="step-increment">0.10</property>
    <property name="upper">1</property>
    <property name="value">0.80</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_unsharp_coeff">
    <property name="page-increment">10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">15</property>
    <property name="value">5</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_unsharp_sigma">
    <property name="page-increment">10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">15</property>
    <property name="value">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustmentscalemax">
    <property name="lower">1</property>
    <property name="page-increment">1000</property>
    <property name="step-increment">20</property>
    <property name="upper">65535</property>
    <property name="value">65535</property>
  </object>
  <object class="GtkAdjustment" id="adjustmentscalemin">
    <property name="page-increment">1000</property>
    <property name="step-increment">20</property>
    <property name="upper">65535</property>
  </object>
  <object class="GtkAdjustment" id="clamp_adjustment">
    <property name="page-increment">0.10</property>
    <property name="step-increment">0.01</property>
    <property name="upper">1</property>
    <property name="value">0.5</property>
  </object>
  <object class="GtkPopover" id="main_menu">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">2</property>
        <child>
          <object class="GtkButton" id="main_menu_preferences">
            <property name="action-name">app.preferences</property>
            <property name="halign">start</property>
            <property name="label" translatable="yes">Preferences</property>
            <signal name="clicked" handler="on_popover_menu_item_clicked"/>
          </object>
        </child>
        <child>
          <object class="GtkSeparator" id="main_menu_separator"/>
        </child>
        <child>
          <object class="GtkButton" id="main_menu_doc">
            <property name="action-name">win.documentation</property>
            <property name="halign">start</property>
            <property name="label" translatable="yes">Siril Manual</property>
            <signal name="clicked" handler="on_popover_menu_item_clicked"/>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="main_menu_updates">
            <property name="action-name">win.updates</property>
            <property name="halign">start</property>
            <property name="label" translatable="yes">Check For Updates</property>
            <signal name="clicked" handler="on_popover_menu_item_clicked"/>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="main_menu_shortcuts">
            <property name="action-name">win.shortcuts</property>
            <property name="halign">start</property>
            <property name="label" translatable="yes">Keyboard Shortcuts</property>
            <signal name="clicked" handler="on_popover_menu_item_clicked"/>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="main_menu_about">
            <property name="action-name">app.about</property>
            <property name="halign">start</property>
            <property name="label" translatable="yes">About Siril</property>
            <signal name="clicked" handler="on_popover_menu_item_clicked"/>
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkPopover" id="menu_display">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkCheckButton" id="linear_item">
