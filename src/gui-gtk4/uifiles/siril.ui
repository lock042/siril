                <child>
                  <object class="GtkButton" id="proc_star_recomp">
                    <property name="action-name">win.star-remix-processing</property>
                    <property name="label" translatable="yes">Star Recomposition...</property>
                    <property name="tooltip-text" translatable="yes">Blends a starless image and star mask, each with separate stretches applied</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="proc_star_desaturate">
                    <property name="action-name">win.star-desaturate</property>
                    <property name="label" translatable="yes">Desaturate Stars</property>
                    <property name="tooltip-markup" translatable="yes">Desaturates clipped star profiles and rescales output to not exceed the maximum 16-bit or 32-bit pixel range. Should be applied &lt;i&gt;before&lt;/i&gt; &lt;b&gt;stretching&lt;/b&gt; to achieve the best result.</property>
                  </object>
                </child>
                <child>
                  <object class="GtkBox">
                    <child>
                      <object class="GtkButton" id="proc_star_synthetic">
                        <property name="action-name">win.star-synthetic</property>
                        <!-- Fill the row so the Dynamic-PSF icon button sits at the end
                             (GTK3 used a full-width GtkModelButton + pack-type=end icon). -->
                        <property name="hexpand">1</property>
                        <property name="label" translatable="yes">Full Resynthesis</property>
                        <property name="tooltip-markup" translatable="yes">Create synthetic Gaussian / Moffat star mask with perfect profiles for every star detected by Siril's star finder routine, using parameters measured from the original data. The star mask can be recombined with a starless image to fix aberrations.
        Star synthesis should be applied &lt;i&gt;before&lt;/i&gt; &lt;b&gt;stretching&lt;/b&gt;.
        Star selection can be manually fine-tuned using the Dynamic PSF tool.</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton">
                        <property name="action-name">win.dyn-psf</property>
                        <property name="focusable">1</property>
                        <property name="receives-default">1</property>
