            <property name="receives-default">1</property>
            <property name="tooltip-text" translatable="1">Bit-depth select button</property>
            <property name="popover">precision_menu</property>
            <child>
              <object class="GtkBox" id="precision_button_box">
                <child>
                  <object class="GtkLabel" id="precision_button_name">
