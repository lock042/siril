                    <property name="tooltip-text" translatable="1">Rotate 90 degrees, counter-clockwise</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>
                    <property name="action-name">win.rotation270-processing</property>
                    <property name="use-underline">1</property>
                    <child>
                      <object class="GtkImage" id="rotate90-acw">
                        <property name="resource">/org/siril/ui/pixmaps/rotate-acw_dark.svg</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/org/siril/ui/pixmaps/rotate-acw_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="rotate90_clock_button">
                    <property name="name">rotate90_clock_button</property>
                    <property name="tooltip-text" translatable="1">Rotate 90 degrees, clockwise</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>
                    <property name="action-name">win.rotation90-processing</property>
                    <property name="use-underline">1</property>
                    <child>
                      <object class="GtkImage" id="rotate90-cw">
                        <property name="resource">/org/siril/ui/pixmaps/rotate-cw_dark.svg</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/org/siril/ui/pixmaps/rotate-cw_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="mirrorx_button">
                    <property name="name">mirrorx_button</property>
                    <property name="tooltip-text" translatable="1">Horizontal mirror</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>
                    <property name="action-name">win.mirrorx-processing</property>
                    <property name="use-underline">1</property>
                    <child>
                      <object class="GtkImage" id="image_mirrorx">
                        <property name="resource">/org/siril/ui/pixmaps/mirrorx_dark.svg</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/org/siril/ui/pixmaps/mirrorx_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="mirrory_button">
                    <property name="name">mirrory_button</property>
                    <property name="tooltip-text" translatable="1">Vertical mirror</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>
                    <property name="action-name">win.mirrory-processing</property>
                    <property name="use-underline">1</property>
                    <child>
                      <object class="GtkImage" id="image_mirrory">
                        <property name="resource">/org/siril/ui/pixmaps/mirrory_dark.svg</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/org/siril/ui/pixmaps/mirrory_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkSeparator" id="separateur6">
                    <property name="orientation">vertical</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="seqlist_button">
                    <property name="name">seqlist_button</property>
                    <property name="tooltip-text" translatable="1">Show/Hide list of images in the sequence with registration data</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>
                    <property name="action-name">win.seq-list</property>
                    <property name="use-underline">1</property>
                    <child>
                      <object class="GtkImage" id="image_seqlist">
                        <property name="resource">/org/siril/ui/pixmaps/list.svg</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/org/siril/ui/pixmaps/list.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <style>
                  <class name="main-toolbar" />
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkPopover" id="popover_catalogs">
    <property name="child">
      <object class="GtkScrolledWindow" id="scrolled_popover_catalogue">
        <property name="height-request">220</property>
        <property name="width-request">260</property>
        <child>
          <placeholder />
        </child>
      </object>
    </property>
  </object>
</interface>