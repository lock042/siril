                                                            <property name="label" translatable="1">Convert</property>
                                                            <property name="sensitive">0</property>
                                                            <property name="focusable">1</property>
                                                            <property name="receives-default">1</property>
                                                            <property name="tooltip-text" translatable="1">Start conversion of all source files into the configured output files, FITS or SER, with colour processing or not.</property>
                                                            <signal name="clicked" handler="on_convert_button_clicked" swapped="no" />
                                                            <style>
                                                              <class name="suggested-action" />
                                                            </style>
                                                            <layout>
                                                              <property name="column">0</property>
                                                              <property name="row">1</property>
                                                              <property name="column-span">2</property>
                                                            </layout>
                                                          </object>
                                                        </child>
                                                        <child>
                                                          <object class="GtkDropDown" id="prepro_output_type_combo1">
                                                            <property name="model">
                                                              <object class="GtkStringList">
                                                                <items>
                                                                  <item translatable="yes">FITS images</item>
                                                                  <item translatable="yes">SER sequence</item>
                                                                  <item translatable="yes">FITS sequence</item>
                                                                </items>
                                                              </object>
                                                            </property>
                                                            <property name="tooltip-text" translatable="1">This sets the destination sequence type.
FITS images: one FITS file per image.
SER sequence: one SER file for the whole sequence (limited to 16 bits per channel).
FITS sequence: one FITS file for the whole sequence.

Note: FITS images will have no effect when the pre-processed sequence is SER or FITS sequence file.</property>
                                                            <property name="selected">0</property>
                                                            <signal name="notify::selected" handler="on_prepro_output_type_combo1_changed" swapped="no" />
                                                            <layout>
                                                              <property name="column">3</property>
                                                              <property name="row">0</property>
                                                            </layout>
                                                          </object>
                                                        </child>
