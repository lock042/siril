                    <property name="label" translatable="1">32 bits</property>
                    <property name="use-underline">1</property>
                  </object>
                </child>
                <child>
                  <object class="GtkImage" id="precision_button_arrow">
                    <property name="valign">baseline-fill</property>
                    <property name="icon-name">pan-down-symbolic</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <!-- The original Save / Save-As / Snapshot trio used to live inside a
             single GtkBox.  Flattening that box means the three buttons
             become individual `<child type="end">` items, which the header
             bar renders right-to-left in declaration order — so to keep
             the visual L→R order Save | Save-As | Snapshot we declare
             them in REVERSE: Snapshot first, then Save-As, then Save. -->
        <child type="end">
          <object class="GtkMenuButton" id="header_snapshot_button">
            <property name="focusable">1</property>
            <property name="receives-default">1</property>
            <property name="tooltip-text" translatable="1">Take a snapshot of your displayed image.</property>
            <property name="popover">snapshot_menu</property>
            <child>
              <object class="GtkBox" id="snapshot_button_box">
                <child>
                  <object class="GtkImage">
                    <property name="icon-name">camera-photo-symbolic</property>
                  </object>
                </child>
                <child>
                  <object class="GtkImage" id="snapshot_button_arrow">
                    <property name="valign">baseline-fill</property>
                    <property name="icon-name">pan-down-symbolic</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child type="end">
          <object class="GtkButton" id="header_save_as_button">
            <property name="focusable">1</property>
            <property name="receives-default">1</property>
            <property name="tooltip-text" translatable="1">Save the current image in a different name</property>
            <property name="action-name">app.save-as</property>
            <property name="use-underline">1</property>
            <child>
              <object class="GtkImage">
                <property name="icon-name">document-save-as-symbolic</property>
              </object>
            </child>
            <style>
              <class name="image-button" />
            </style>
          </object>
        </child>
        <child type="end">
          <object class="GtkButton" id="header_save_button">
            <property name="label" translatable="1">Save</property>
            <property name="name">save-button</property>
            <property name="focusable">1</property>
            <property name="receives-default">1</property>
            <property name="tooltip-text" translatable="1">Save the current FITS image</property>
            <property name="action-name">app.save</property>
            <property name="use-underline">1</property>
          </object>
        </child>
        <child type="end">
          <object class="GtkSpinButton" id="spinCPU">
            <property name="focusable">1</property>
            <property name="tooltip-text" translatable="1">Set number of threads manually.
WARNING: Reducing the number of allowed processors too much will degrade performances.</property>
            <property name="margin-bottom">1</property>
            <property name="width-chars">3</property>
            <property name="max-width-chars">2</property>
            <property name="text">1</property>
            <property name="adjustment">adjCPU</property>
            <property name="numeric">1</property>
            <property name="update-policy">if-valid</property>
            <property name="value">1</property>
            <signal name="value-changed" handler="on_spinCPU_value_changed" swapped="no" />
            <style>
              <class name="small-spinbutton" />
            </style>
          </object>
        </child>
        <child type="end">
          <object class="GtkBox" id="GtkBoxMem">
            <property name="halign">center</property>
            <property name="valign">center</property>
            <property name="orientation">vertical</property>
            <child>
              <object class="GtkLabel" id="labelmem">
                <property name="tooltip-text" translatable="1">Displays the amount of used RAM memory by Siril.</property>
                <property name="halign">end</property>
