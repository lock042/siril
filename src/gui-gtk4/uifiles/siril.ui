                                                          <object class="GtkBox">
                                                            <child>
                                                              <object class="GtkCheckButton" id="multiple_seq">
                                                                <property name="visible">0</property>
                                                                <property name="label" translatable="1">Multiple sequences</property>
                                                                <property name="focusable">1</property>
                                                                <property name="tooltip-text" translatable="1">Tick this to create several sequence files instead of a single SER or FITS file for all input elements. Use this if input elements (sequence files such as films, SER or FITS cubes) don't share the same image size or must not be processed together.</property>
                                                                <property name="halign">start</property>
                                                              </object>
                                                            </child>
                                                            <child>
                                                              <object class="GtkCheckButton" id="convert_symlink">
                                                                <property name="label" translatable="1">Symbolic Link</property>
                                                                <property name="focusable">1</property>
                                                                <property name="tooltip-markup" translatable="1">Create a symbolic link for FITS files instead of copying them. This is useful to rename a sequence without duplicating files on the disk. This option disables compression.

&lt;b&gt;WARNING: on Windows, the symbolic link operations are only possible in Development mode.&lt;/b&gt;</property>
                                                                <property name="halign">start</property>
                                                                <property name="active">1</property>
                                                              </object>
                                                            </child>
                                                            <child>
                                                              <object class="GtkCheckButton" id="demosaicingButton">
                                                                <property name="label" translatable="1">Debayer</property>
                                                                <property name="focusable">1</property>
                                                                <property name="tooltip-text" translatable="1">Debayer single-channel images (CFA format) using the Bayer matrix layout given in the settings. Also applies to image opening, not only conversion.
Only for RAW and FITS input images and SER films.
Colour image target also applies to the debayer result for conversion.</property>
                                                                <property name="halign">start</property>
                                                                <signal name="toggled" handler="on_demosaicing_toggled" swapped="no" />
                                                              </object>
                                                            </child>
