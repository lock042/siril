                                                            </layout>
                                                          </object>
                                                        </child>
                                                        <child>
                                                          <object class="GtkEntry" id="convroot_entry">
                                                            <property name="focusable">1</property>
                                                            <property name="tooltip-text" translatable="1">Enter the base name of the sequence, for example NGC_6822-L. It will create images in the form NGC_6822-L_00001.fit.</property>
                                                            <property name="valign">center</property>
                                                            <property name="hexpand">1</property>
                                                            <property name="input-hints">GTK_INPUT_HINT_NO_EMOJI | GTK_INPUT_HINT_NONE</property>
                                                            <signal name="activate" handler="on_conv_root_entry_activate" swapped="no" />
                                                            <signal name="changed" handler="on_convtoroot_changed" swapped="no" />
                                                            <signal name="insert-text" handler="insert_text_handler" swapped="no" />
                                                            <layout>
                                                              <property name="column">1</property>
                                                              <property name="row">0</property>
                                                            </layout>
                                                          </object>
                                                        </child>
