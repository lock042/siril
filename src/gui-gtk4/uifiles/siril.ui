                <property name="justify">right</property>
                <property name="single-line-mode">1</property>
                <attributes>
                  <attribute name="scale" value="0.80000000000000004" />
                </attributes>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="labelFreeSpace">
                <property name="tooltip-text" translatable="1">Displays the amount of disk space available on the file system containing the working directory.</property>
                <property name="halign">end</property>
                <property name="label" translatable="1" context="GUI" comments="Must be short !!">Disk Space: N/A</property>
                <property name="justify">right</property>
                <property name="single-line-mode">1</property>
                <attributes>
                  <attribute name="scale" value="0.80000000000000004" />
                </attributes>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
