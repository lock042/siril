    <property name="value">0.5</property>
    <property name="step-increment">0.01</property>
    <property name="page-increment">0.10</property>
  </object>
  <object class="GtkPopover" id="clear_menu">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkButton" id="clearAllPhotometry">
            <property name="tooltip-text" translatable="1">Clear all curves displayed in photometry.</property>
            <property name="label" translatable="1">Clear all</property>
            <property name="has-frame">0</property>
            <signal name="clicked" handler="on_clearAllPhotometry_clicked" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkButton" id="clearLastPhotometry">
            <property name="tooltip-text" translatable="1">Clear the last curve added in photometry.</property>
            <property name="label" translatable="1">Clear latest</property>
            <property name="has-frame">0</property>
            <signal name="clicked" handler="on_clearLatestPhotometry_clicked" swapped="no" />
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkPopover" id="display_plot_menu">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <child>
          <object class="GtkCheckButton" id="JulianPhotometry">
            <property name="label" translatable="1">Julian Date</property>
            <property name="focusable">1</property>
            <signal name="toggled" handler="on_JulianPhotometry_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="label_display_plot">
            <property name="margin-start">5</property>
            <property name="margin-end">5</property>
            <property name="margin-top">5</property>
            <property name="margin-bottom">5</property>
            <property name="label" translatable="1">Nothing to change</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="arcsecPhotometry">
            <property name="label" translatable="1">arcsec</property>
            <property name="focusable">1</property>
            <signal name="toggled" handler="on_arcsecPhotometry_toggled" swapped="no" />
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkPopover" id="main_menu">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">2</property>
        <child>
          <object class="GtkButton" id="main_menu_preferences">
            <property name="label" translatable="1">Preferences</property>
            <property name="action-name">app.preferences</property>
            <signal name="clicked" handler="on_popover_menu_item_clicked" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkSeparator" />
        </child>
        <child>
          <object class="GtkButton" id="main_menu_doc">
            <property name="label" translatable="1">Siril Manual</property>
            <property name="action-name">win.documentation</property>
            <signal name="clicked" handler="on_popover_menu_item_clicked" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkButton" id="main_menu_updates">
            <property name="label" translatable="1">Check For Updates</property>
            <property name="action-name">win.updates</property>
            <signal name="clicked" handler="on_popover_menu_item_clicked" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkButton" id="main_menu_shortcuts">
            <property name="label" translatable="1">Keyboard Shortcuts</property>
            <property name="action-name">win.shortcuts</property>
            <signal name="clicked" handler="on_popover_menu_item_clicked" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkButton" id="main_menu_about">
            <property name="label" translatable="1">About Siril</property>
            <property name="action-name">app.about</property>
            <signal name="clicked" handler="on_popover_menu_item_clicked" swapped="no" />
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkPopover" id="menu_display">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkCheckButton" id="linear_item">
            <property name="visible">True</property>
            <property name="label" translatable="1">Linear</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_display_item_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="log_item">
            <property name="visible">True</property>
            <property name="label" translatable="1">Logarithm</property>
            <property name="group">linear_item</property>
            <signal name="toggled" handler="on_display_item_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="square_root_item">
            <property name="visible">True</property>
            <property name="label" translatable="1">Square root</property>
            <property name="group">linear_item</property>
            <signal name="toggled" handler="on_display_item_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="squared_item">
            <property name="visible">True</property>
            <property name="label" translatable="1">Squared</property>
            <property name="group">linear_item</property>
            <signal name="toggled" handler="on_display_item_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="asinh_item">
            <property name="visible">True</property>
            <property name="label" translatable="1">Asinh</property>
            <property name="group">linear_item</property>
            <signal name="toggled" handler="on_display_item_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="auto_item">
            <property name="visible">True</property>
            <property name="label" translatable="1">AutoStretch</property>
            <property name="group">linear_item</property>
            <signal name="toggled" handler="on_display_item_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="autohd_item">
            <property name="visible">True</property>
            <property name="margin-start">18</property>
            <property name="label" translatable="1">High definition</property>
            <signal name="toggled" handler="on_autohd_item_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="histo_item">
            <property name="visible">True</property>
            <property name="label" translatable="1">Histogram</property>
            <property name="group">linear_item</property>
            <signal name="toggled" handler="on_display_item_toggled" swapped="no" />
          </object>
        </child>
      </object>
    </property>
  </object>
