                  <object class="GtkToggleButton" id="annotate_button">
                    <property name="action-name">win.annotate-object</property>
                    <property name="tooltip-text" translatable="yes">Left-click to show object names if WCS information is available. Right-click to display a list of astro catalogs to choose from.</property>
                    <property name="use-underline">1</property>
                    <child>
                      <object class="GtkImage" id="astrometry">
                        <property name="resource">/org/siril/ui/pixmaps/astrometry_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkToggleButton" id="wcs_grid_button">
                    <property name="action-name">win.wcs-grid</property>
                    <property name="tooltip-text" translatable="yes">Show celestial grid if WCS information is available</property>
                    <property name="use-underline">1</property>
                    <child>
                      <object class="GtkImage" id="image3">
                        <property name="resource">/org/siril/ui/pixmaps/wcs-grid_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkSeparator" id="separateur">
                    <property name="orientation">vertical</property>
                  </object>
                </child>
                <child>
                  <object class="GtkToggleButton" id="photometry_button">
                    <property name="action-name">win.photometry</property>
                    <property name="tooltip-text" translatable="yes">Switch to PSF/photometry mode. If a sequence is loaded, a right click on the displayed image applies the PSF/Photometry on the whole sequence.</property>
                    <property name="use-underline">1</property>
                    <child>
                      <object class="GtkImage" id="photometry">
                        <property name="resource">/org/siril/ui/pixmaps/photometry_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkToggleButton" id="cut_button">
                    <property name="action-name">win.cut</property>
                    <property name="tooltip-text" translatable="yes">Make an intensity profile cut, showing a graph of the pixel value along a line between two points</property>
                    <property name="use-underline">1</property>
                    <child>
                      <object class="GtkImage" id="image_cut">
                        <property name="resource">/org/siril/ui/pixmaps/cut_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkSeparator" id="separateur4">
                    <property name="orientation">vertical</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="zoom_out">
                    <property name="action-name">win.zoom-out</property>
                    <property name="icon-name">zoom-out-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Shrink the image</property>
                    <property name="use-underline">1</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="zoom_in">
                    <property name="action-name">win.zoom-in</property>
                    <property name="icon-name">zoom-in-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Enlarge the image</property>
                    <property name="use-underline">1</property>
                  </object>
                </child>
                <child>
                  <object class="GtkToggleButton" id="zoom_to_fit_check_button">
                    <property name="action-name">win.zoom-fit</property>
                    <property name="active">1</property>
                    <property name="halign">center</property>
                    <property name="icon-name">zoom-fit-best-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Fit the image to the window</property>
                    <property name="use-underline">1</property>
                    <property name="valign">center</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="zoom_to_one_button">
                    <property name="action-name">win.zoom-one</property>
                    <property name="halign">center</property>
                    <property name="icon-name">zoom-original-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Show the image at its normal size</property>
                    <property name="use-underline">1</property>
                    <property name="valign">center</property>
                  </object>
                </child>
                <child>
                  <object class="GtkSeparator" id="separateur1">
                    <property name="orientation">vertical</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="rotate90_anticlock_button">
                    <property name="action-name">win.rotation270-processing</property>
                    <property name="halign">center</property>
                    <property name="name">rotate90_anticlock_button</property>
                    <property name="tooltip-text" translatable="yes">Rotate 90 degrees, counter-clockwise</property>
                    <property name="use-underline">1</property>
                    <property name="valign">center</property>
                    <child>
                      <object class="GtkImage" id="rotate90-acw">
                        <property name="resource">/org/siril/ui/pixmaps/rotate-acw_dark.svg</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/org/siril/ui/pixmaps/rotate-acw_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="rotate90_clock_button">
                    <property name="action-name">win.rotation90-processing</property>
                    <property name="halign">center</property>
                    <property name="name">rotate90_clock_button</property>
                    <property name="tooltip-text" translatable="yes">Rotate 90 degrees, clockwise</property>
                    <property name="use-underline">1</property>
                    <property name="valign">center</property>
                    <child>
                      <object class="GtkImage" id="rotate90-cw">
                        <property name="resource">/org/siril/ui/pixmaps/rotate-cw_dark.svg</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/org/siril/ui/pixmaps/rotate-cw_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="mirrorx_button">
                    <property name="action-name">win.mirrorx-processing</property>
                    <property name="halign">center</property>
                    <property name="name">mirrorx_button</property>
                    <property name="tooltip-text" translatable="yes">Horizontal mirror</property>
                    <property name="use-underline">1</property>
                    <property name="valign">center</property>
                    <child>
                      <object class="GtkImage" id="image_mirrorx">
                        <property name="resource">/org/siril/ui/pixmaps/mirrorx_dark.svg</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/org/siril/ui/pixmaps/mirrorx_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="mirrory_button">
                    <property name="action-name">win.mirrory-processing</property>
                    <property name="halign">center</property>
                    <property name="name">mirrory_button</property>
                    <property name="tooltip-text" translatable="yes">Vertical mirror</property>
                    <property name="use-underline">1</property>
                    <property name="valign">center</property>
                    <child>
                      <object class="GtkImage" id="image_mirrory">
                        <property name="resource">/org/siril/ui/pixmaps/mirrory_dark.svg</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/org/siril/ui/pixmaps/mirrory_dark.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkSeparator" id="separateur6">
                    <property name="orientation">vertical</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="seqlist_button">
                    <property name="action-name">win.seq-list</property>
                    <property name="halign">center</property>
                    <property name="name">seqlist_button</property>
                    <property name="tooltip-text" translatable="yes">Show/Hide list of images in the sequence with registration data</property>
                    <property name="use-underline">1</property>
                    <property name="valign">center</property>
                    <child>
                      <object class="GtkImage" id="image_seqlist">
                        <property name="resource">/org/siril/ui/pixmaps/list.svg</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/org/siril/ui/pixmaps/list.svg</property>
                      </object>
                    </child>
                  </object>
                </child>
                <style>
                  <class name="main-toolbar"/>
                </style>
              </object>
            </child>
            <style>
              <class name="toolbar"/>
            </style>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkPopover" id="popover_catalogs">
    <property name="child">
      <object class="GtkScrolledWindow" id="scrolled_popover_catalogue">
        <property name="height-request">220</property>
        <property name="width-request">260</property>
      </object>
    </property>
  </object>
</interface>
