<?xml version='1.0' encoding='UTF-8'?>
<interface>
  <requires lib="gtk" version="4.0" />
  <object class="GtkAdjustment" id="adjustment_epf_d">
    <property name="upper">20</property>
    <property name="step-increment">0.10</property>
    <property name="page-increment">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_epf_sigma_col">
    <property name="upper">65535</property>
    <property name="value">11</property>
    <property name="step-increment">0.10</property>
    <property name="page-increment">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_epf_sigma_spatial">
    <property name="upper">20</property>
    <property name="value">11</property>
    <property name="step-increment">0.10</property>
    <property name="page-increment">1</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_spin_epf_mod">
    <property name="upper">1</property>
    <property name="value">1</property>
    <property name="step-increment">0.01</property>
    <property name="page-increment">0.10</property>
  </object>
  <object class="GtkDialog" id="epf_dialog">
    <property name="width-request">400</property>
    <property name="height-request">200</property>
    <property name="title" translatable="1">Edge Preserving Filters</property>
    <property name="resizable">0</property>
    <signal name="close-request" handler="siril_widget_hide_on_delete" swapped="no" />
    <signal name="hide" handler="apply_epf_cancel" swapped="no" />
    <signal name="show" handler="on_epf_dialog_show" swapped="no" />
    <child internal-child="content_area">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">10</property>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkBox">
                <property name="homogeneous">1</property>
                <child>
                  <object class="GtkLabel">
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Filter Type</property>
                  </object>
                </child>
                <child>
                  <object class="GtkDropDown" id="ep_filter_type">
                    <property name="model">
                      <object class="GtkStringList">
                        <items>
                          <item translatable="yes">Bilateral filter</item>
                          <item translatable="yes">Guided filter</item>
                        </items>
                      </object>
                    </property>
                    <property name="tooltip-text" translatable="1">Choose filter type. See the documentation for an explanation of the differences.</property>
                    <property name="selected">0</property>
                    <signal name="notify::selected" handler="on_ep_filter_type_changed" swapped="no" />
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkGrid" id="guide_image_widgets">
                <property name="name">guided_filter_settings</property>
                <property name="column-homogeneous">1</property>
                <child>
                  <object class="GtkLabel">
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Guide Image</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="guided_filter_guideimage">
                    <property name="label">(None)</property>
                    <property name="visible">True</property>
                    <property name="tooltip-text" translatable="1">Select guide image. No need to select a file if the "self guided" check box is checked.
WARNING: using guide images that are not based on the original image is likely to produce bad results.</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkCheckButton" id="guided_filter_selfguide">
                    <property name="label" translatable="1">self guided</property>
                    <property name="sensitive">0</property>
                    <property name="focusable">1</property>
                    <property name="tooltip-text" translatable="1">Check this to use the current image as the guided filter guide image</property>
                    <property name="active">1</property>
                    <signal name="toggled" handler="on_guided_filter_selfguide_toggled" swapped="no" />
                    <layout>
                      <property name="column">0</property>
                      <property name="row">1</property>
                      <property name="column-span">2</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="homogeneous">1</property>
                <child>
                  <object class="GtkLabel" id="label176">
                    <property name="tooltip-text" translatable="1">If set to 0, the diameter will automatically be set based on the spatial sigma parameter</property>
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Diameter</property>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_epf_d">
                    <property name="focusable">1</property>
                    <property name="tooltip-text" translatable="1">This sets the diameter the edge preserving filter applies over. If it is zero, the spatial extent is set automatically based on the spatial sigma value, otherwise the spatial extent of the filter is set to exactly this value regardless of sigma (spatial)</property>
                    <property name="text">0.0</property>
                    <property name="adjustment">adjustment_epf_d</property>
                    <property name="digits">1</property>
                    <property name="numeric">1</property>
                    <signal name="value-changed" handler="on_epf_parameter_changed" swapped="no" />
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkScale" id="scale_epf_d">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">This affects the diameter the filter applies over. If it is zero, the spatial extent is set by the spatial sigma value.</property>
                <property name="hexpand">1</property>
                <property name="adjustment">adjustment_epf_d</property>
                <property name="value-pos">bottom</property>
              </object>
            </child>
            <child>
              <object class="GtkGrid" id="epf_sigma_spatial_settings">
                <property name="row-spacing">6</property>
                <property name="column-spacing">6</property>
                <property name="column-homogeneous">1</property>
                <child>
                  <object class="GtkLabel" id="label1">
                    <property name="tooltip-text" translatable="1">If set to 0, the diameter will automatically be set based on the spatial sigma parameter</property>
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Sigma (spatial)</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_epf_sigma_spatial">
                    <property name="focusable">1</property>
                    <property name="tooltip-text" translatable="1">Sets the range of spatial distance between pixels over which the filter operates. A larger sigma means the filter takes into account pixels over a wider area of the image. Note the interaction with the diameter setting.</property>
                    <property name="text">0.0</property>
                    <property name="adjustment">adjustment_epf_sigma_spatial</property>
                    <property name="digits">2</property>
                    <property name="numeric">1</property>
                    <signal name="value-changed" handler="on_epf_parameter_changed" swapped="no" />
                    <layout>
                      <property name="column">1</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkScale">
                    <property name="focusable">1</property>
                    <property name="adjustment">adjustment_epf_sigma_spatial</property>
                    <property name="round-digits">1</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">1</property>
                      <property name="column-span">2</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="spacing">6</property>
                <property name="homogeneous">1</property>
                <child>
                  <object class="GtkLabel" id="label177">
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Sigma (intensity)</property>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_epf_sigma_col">
                    <property name="focusable">1</property>
                    <property name="tooltip-text" translatable="1">This value affects the range of pixel value similarity the edge preserving filter aplies over.
If your stars look huge and defocused, start by reducing this value. Depending on your data you may need to make substantial adjustments here, for example setting the value to below 1.0.</property>
                    <property name="text">0.000</property>
                    <property name="adjustment">adjustment_epf_sigma_col</property>
                    <property name="digits">2</property>
                    <property name="numeric">1</property>
                    <signal name="value-changed" handler="on_epf_parameter_changed" swapped="no" />
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkGrid" id="epf_mod_settings">
                <property name="row-spacing">6</property>
                <property name="column-spacing">6</property>
                <property name="column-homogeneous">1</property>
                <child>
                  <object class="GtkLabel">
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Modulation</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_epf_mod">
                    <property name="focusable">1</property>
                    <property name="tooltip-text" translatable="1">Modulation parameter set in the [0, 1] range.
When this parameter is equal to 1, no modulation is applied.
If the parameters is 0, no filter is applied at all.</property>
                    <property name="adjustment">adjustment_spin_epf_mod</property>
                    <property name="digits">2</property>
                    <property name="value">1</property>
                    <signal name="value-changed" handler="on_epf_parameter_changed" swapped="no" />
                    <layout>
                      <property name="column">1</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkScale">
                    <property name="focusable">1</property>
                    <property name="tooltip-text" translatable="1">Modulation parameter set in the [0, 1] range.
When this parameter is equal to 1, no modulation is applied.
If the parameters is 0, no filter is applied at all.</property>
                    <property name="adjustment">adjustment_spin_epf_mod</property>
                    <property name="round-digits">1</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">1</property>
                      <property name="column-span">2</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="epf_preview">
            <property name="label" translatable="1">Preview</property>
            <property name="focusable">1</property>
            <property name="tooltip-text" translatable="1">Edge preserving filters can be slow on large images, so preview is not active by default. It is strongly recommended to select a Region of Interest (ROI) before activating the edge preserving filter preview.</property>
            <property name="halign">start</property>
            <signal name="toggled" handler="on_epf_preview_toggled" swapped="no" />
          </object>
        </child>
      </object>
    </child>
    <action-widgets>
      <action-widget response="0">epf_apply</action-widget>
    </action-widgets>
    <child internal-child="action_area">
      <object class="GtkBox">
        <property name="spacing">6</property>
        <property name="halign">end</property>
        <property name="orientation">horizontal</property>
        <child>
          <object class="GtkButton" id="epf_undo">
            <property name="label" translatable="1">Reset</property>
            <property name="focusable">1</property>
            <property name="receives-default">1</property>
            <signal name="clicked" handler="on_epf_undo_clicked" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkButton" id="epf_cancel">
            <property name="label" translatable="1">Cancel</property>
            <property name="focusable">1</property>
            <property name="receives-default">1</property>
            <signal name="clicked" handler="on_epf_cancel_clicked" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkButton" id="epf_apply">
            <property name="label" translatable="1">Apply</property>
            <property name="focusable">1</property>
            <property name="receives-default">1</property>
            <signal name="clicked" handler="on_epf_apply_clicked" swapped="no" />
            <style>
              <class name="suggested-action" />
            </style>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>