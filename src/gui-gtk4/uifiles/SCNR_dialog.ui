<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name SCNR_dialog.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkAdjustment" id="adjustment_scnr">
    <property name="page-increment">0.10</property>
    <property name="step-increment">0.10</property>
    <property name="upper">1</property>
    <property name="value">1</property>
  </object>
  <object class="GtkWindow" id="SCNR_dialog">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox" id="dialog-vbox8">
            <property name="margin-bottom">6</property>
            <property name="margin-end">6</property>
            <property name="margin-start">6</property>
            <property name="margin-top">6</property>
            <property name="orientation">vertical</property>
            <property name="spacing">10</property>
            <child>
              <object class="GtkBox">
                <property name="spacing">10</property>
                <child>
                  <object class="GtkLabel" id="label169">
                    <property name="halign">start</property>
                    <property name="label" translatable="yes">Protection method: </property>
                  </object>
                </child>
                <child>
                  <object class="GtkDropDown" id="combo_scnr">
                    <property name="halign">start</property>
                    <property name="hexpand">1</property>
                    <property name="model">
                      <object class="GtkStringList">
                        <items>
                          <item translatable="yes">Average Neutral</item>
                          <item translatable="yes">Maximum Neutral</item>
                          <item translatable="yes">Maximum Mask</item>
                          <item translatable="yes">Additive Mask</item>
                        </items>
                      </object>
                    </property>
                    <property name="selected">0</property>
                    <property name="tooltip-text" translatable="yes">Average Neutral Protection is the default option. This is the recommended option in most cases.</property>
                    <signal name="notify::selected" handler="on_combo_scnr_changed"/>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <child>
                  <object class="GtkLabel" id="label56">
                    <property name="halign">start</property>
                    <property name="label" translatable="yes">Amount</property>
                    <property name="sensitive">0</property>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_scnr">
                    <property name="adjustment">adjustment_scnr</property>
                    <property name="digits">2</property>
                    <property name="focusable">1</property>
                    <property name="sensitive">0</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkScale" id="scale_scnr">
                <property name="adjustment">adjustment_scnr</property>
                <property name="digits">2</property>
                <property name="focusable">1</property>
                <property name="hexpand">1</property>
                <property name="round-digits">2</property>
                <property name="sensitive">0</property>
                <property name="value-pos">bottom</property>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="preserve_light">
                <property name="active">1</property>
                <property name="focusable">1</property>
                <property name="halign">end</property>
                <property name="label" translatable="yes">Preserve lightness</property>
                <property name="tooltip-text" translatable="yes">Preserves the original CIE L* component in the processed image.</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="dialog-action_area8">
            <property name="halign">end</property>
            <property name="margin-bottom">12</property>
            <property name="margin-end">12</property>
            <property name="margin-start">12</property>
            <property name="margin-top">12</property>
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkButton" id="SCNR_cancel">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Close</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_SCNR_cancel_clicked"/>
              </object>
            </child>
            <child>
              <object class="GtkToggleButton" id="SCNR_roi_preview">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">ROI Preview</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_SCNR_Apply_clicked"/>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="SCNR_Apply">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Apply</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_SCNR_Apply_clicked"/>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <property name="height-request">200</property>
    <property name="resizable">0</property>
    <property name="title" translatable="yes">Subtractive Chromatic Green Noise Reduction</property>
    <property name="width-request">400</property>
    <signal name="close-request" handler="siril_widget_hide_on_delete"/>
    <signal name="hide" handler="on_SCNR_cancel_clicked"/>
    <signal name="show" handler="on_SCNR_dialog_show"/>
  </object>
</interface>
