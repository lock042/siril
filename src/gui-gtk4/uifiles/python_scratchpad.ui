<?xml version='1.0' encoding='UTF-8'?>
<interface>
  <requires lib="gtk" version="4.0" />
  <requires lib="gtksourceview" version="5.0" />
  <object class="GtkOverlay" id="find_overlay">
    <property name="child">
      <object class="GtkRevealer" id="find_revealer">
        <property name="transition-type">none</property>
        <property name="reveal-child">1</property>
        <property name="child">
          <object class="GtkSearchBar">
            <property name="search-mode-enabled">1</property>
            <property name="child">
              <object class="GtkBox">
                <property name="spacing">5</property>
                <child>
                  <object class="GtkSearchEntry" id="find_entry">
                    <property name="focusable">1</property>
                    <property name="width-chars">30</property>
                    <signal name="activate" handler="on_find_entry_activate" swapped="no" />
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="find_label">
                    <property name="label">0/0</property>
                    <property name="width-chars">10</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="go_up_button">
                    <child>
                      <object class="GtkImage" id="up_image">
                        <property name="tooltip-text" translatable="1">Previous Result</property>
                        <property name="icon-name">go-up-symbolic</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="go_down_button">
                    <child>
                      <object class="GtkImage" id="down_image">
                        <property name="tooltip-text" translatable="1">Next Result</property>
                        <property name="icon-name">go-down-symbolic</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </property>
      </object>
    </property>
  </object>
  <object class="GtkWindow" id="python_window">
    <property name="title" translatable="1">unsaved</property>
    <property name="default-width">800</property>
    <property name="default-height">600</property>
    <signal name="close-request" handler="siril_widget_hide_on_delete" swapped="no" />
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">2</property>
        <child>
          <object class="GtkBox" id="python_pad_box">
            <property name="vexpand">1</property>
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <property name="visible">True</property>
                <child>
                                    <object class="GtkMenuButton">
                    <property name="label" translatable="1">_File</property>
                    <property name="use-underline">1</property>
                    <property name="popover">pyeditor_menu_file</property>
                  </object>
                </child>
                <child>
                                    <object class="GtkMenuButton">
                    <property name="label" translatable="1">_Edit</property>
                    <property name="use-underline">1</property>
                    <property name="popover">pyeditor_menu_edit</property>
                  </object>
                </child>
                <child>
                                    <object class="GtkMenuButton">
                    <property name="label" translatable="1">_Script</property>
                    <property name="use-underline">1</property>
                    <property name="popover">pyeditor_menu_script</property>
                  </object>
                </child>
                <child>
                                    <object class="GtkMenuButton">
                    <property name="label" translatable="1">_Preferences</property>
                    <property name="use-underline">1</property>
                    <property name="popover">pyeditor_menu_preferences</property>
                  </object>
                </child>
                <child>
                                    <object class="GtkMenuButton">
                    <property name="label" translatable="1">_Help</property>
                    <property name="use-underline">1</property>
                    <property name="popover">pyeditor_menu_help</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="script_language_label">
                <property name="tooltip-text" translatable="1">Script type</property>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="vexpand">1</property>
                <property name="orientation">vertical</property>
                <child>
                  <object class="GtkBox" id="codeviewbox">
                    <child>
                      <object class="GtkScrolledWindow" id="python_scrolled_window">
                        <property name="focusable">1</property>
                        <property name="min-content-width">400</property>
                        <property name="min-content-height">600</property>
                        <property name="propagate-natural-width">1</property>
                        <property name="propagate-natural-height">1</property>
                        <child>
                          <object class="GtkSourceView" id="code_view">
                            </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="editor_args_box">
                    <property name="visible">0</property>
                    <property name="margin-top">6</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="margin-start">6</property>
                        <property name="label" translatable="1">Arguments:</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkEntry" id="editor_args_entry">
                        <property name="focusable">1</property>
                        <property name="tooltip-markup" translatable="1">This entry can be used to set arguments to run the script with, in order to allow testing of how it will behave when called with the &lt;b&gt;pyscript&lt;/b&gt; command with arguments. Note that arguments  cannot be provided when a script is run from the Scripts menu, so scripts should not be solely reliant on arguments for input.</property>
                        <property name="hexpand">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="editor_args_clear">
                        <property name="label">gtk-clear</property>
                        <property name="focusable">1</property>
                        <property name="receives-default">1</property>
                        <property name="halign">end</property>
                        <signal name="clicked" handler="on_editor_args_clear_clicked" swapped="no" />
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkPopover" id="pyeditor_menu_help">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Open Python API reference documentation</property>
            <property name="action-name">editor.python_doc</property>
            <property name="label" translatable="1">Python API reference</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Open Siril command reference documentation</property>
            <property name="action-name">editor.command_doc</property>
            <property name="label" translatable="1">Siril Command Reference</property>
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkPopover" id="pyeditor_menu_preferences">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkCheckButton" id="editor_syntax">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Enable syntax highlighting</property>
            <property name="label" translatable="1">Highlight syntax</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_editor_syntax_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_rmargin">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Enable right margin indicator</property>
            <property name="label" translatable="1">Enable right margin indicator</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_editor_rmargin_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Set the position of the right margin indicator in the editor. This visual guide helps maintain consistent line lengths and improve code readability.</property>
            <property name="action-name">editor.set_rmarginpos</property>
            <property name="label" translatable="1">Set right margin position</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_bracketmatch">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">When enabled, positioning the cursor on a bracket will show the matching bracket</property>
            <property name="label" translatable="1">Enable bracket matching</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_editor_bracketmatch_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_linenums">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Enable line numbers in the left margin</property>
            <property name="label" translatable="1">Show line numbers</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_editor_linenums_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_linemarks">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Show line markers in the left margin</property>
            <property name="label" translatable="1">Show line markers</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_editor_linemarks_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_highlightcurrentline">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Highlight the current line in the editor</property>
            <property name="label" translatable="1">Highlight current line</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_editor_highlightcurrentline_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_autoindent">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Enable auto-indentation</property>
            <property name="label" translatable="1">Enable auto-indentation</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_editor_autoindent_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_indentontab">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">When a block of lines is selected, tab increases the indent level</property>
            <property name="label" translatable="1">Indent on tab</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_editor_indentontab_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_smartbs">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Enable smart backspace</property>
            <property name="label" translatable="1">Enable smart backspace</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_editor_smartbs_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_smarthomeend">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">When Smart Home / End is enabled the Home and End keys will go to the first and last non-whitespace character on the line respectively</property>
            <property name="label" translatable="1">Smart Home / End</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_editor_smarthomeend_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_showspaces">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Show space and tab characters in the editor view</property>
            <property name="label" translatable="1">Show spaces and tabs</property>
            <signal name="toggled" handler="on_editor_showspaces_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_shownewlines">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Show newline characters in the editor view</property>
            <property name="label" translatable="1">Show newlines</property>
            <signal name="toggled" handler="on_editor_shownewlines_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_minimap">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Show minimap in the editor view</property>
            <property name="label" translatable="1">Show minimap</property>
            <signal name="toggled" handler="on_editor_minimap_toggled" swapped="no" />
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkPopover" id="pyeditor_menu_script">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Run the script</property>
            <property name="action-name">editor.execute</property>
            <property name="label" translatable="1">Run</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="radio_py">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Set scripting language to Python. Ensure you have the correct scripting language set before executing a script from the editor.</property>
            <property name="label" translatable="1">Python scripts</property>
            <property name="active">True</property>
            <signal name="toggled" handler="on_language_set" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="radio_ssf">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Set scripting language to Siril Script File. Ensure you have the correct scripting language set before executing a script from the editor.</property>
            <property name="label" translatable="1">Siril Script Files</property>
            <property name="group">radio_py</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_useargs">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">When active, any arguments entered in the args entry will be passed to the script when it is run.
This also ensures SirilInterface is invoked in CLI mode (SirilInterface.is_cli() will return True)</property>
            <property name="label" translatable="1">Enable test arguments</property>
            <signal name="toggled" handler="on_editor_useargs_toggled" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="editor_toggledebug">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">When active, the python interpreter will display a modal dialog showing the python process as soon as the SirilInterface is initialized, to allow for connecting a python debugger to the process before continuing.</property>
            <property name="label" translatable="1">Enable python debug mode</property>
            <signal name="toggled" handler="on_pythondebug_toggled" swapped="no" />
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkPopover" id="pyeditor_menu_edit">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Undo</property>
            <property name="action-name">editor.undo</property>
            <property name="label" translatable="1">Undo</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Redo</property>
            <property name="action-name">editor.redo</property>
            <property name="label" translatable="1">Redo</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Cut</property>
            <property name="action-name">editor.cut</property>
            <property name="label" translatable="1">Cut</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Copy</property>
            <property name="action-name">editor.copy</property>
            <property name="label" translatable="1">Copy</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Paste</property>
            <property name="action-name">editor.paste</property>
            <property name="label" translatable="1">Paste</property>
          </object>
        </child>
        <child>
          <object class="GtkSeparator" id="separator">
            <property name="orientation">horizontal</property>
            <property name="visible">True</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Find</property>
            <property name="action-name">editor.find</property>
            <property name="label" translatable="1">Find</property>
          </object>
        </child>
      </object>
    </property>
  </object>
  <object class="GtkPopover" id="pyeditor_menu_file">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Clear the current script</property>
            <property name="action-name">editor.new</property>
            <property name="label" translatable="1">_New</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Open a script from a file</property>
            <property name="action-name">editor.open</property>
            <property name="label" translatable="1">_Open</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="label" translatable="1">_Recent Files</property>
            <child type="submenu">
              </child>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Save the current script</property>
            <property name="action-name">editor.save</property>
            <property name="label" translatable="1">_Save</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Save the current script (choose filename)</property>
            <property name="action-name">editor.save_as</property>
            <property name="label" translatable="1">_Save As</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="visible">True</property>
            <property name="tooltip-text" translatable="1">Close the script editor</property>
            <property name="action-name">editor.close</property>
            <property name="label" translatable="1">Close</property>
          </object>
        </child>
      </object>
    </property>
  </object>
</interface>