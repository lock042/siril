            <child>
              <object class="GtkButton" id="button_savepopup">
                <property name="label" translatable="1">Save</property>
                <property name="sensitive">0</property>
                <property name="focusable">1</property>
                <property name="receives-default">1</property>
                <property name="tooltip-text" translatable="1">Note: when embedding ICC profiles libjxl will check if it recognises the profile. If it does, it will set a reference value rather than store the entire profile. This means that when you re-open the file the ICC profile description may be different, although it will be functionally equivalent.</property>
                <signal name="clicked" handler="on_button_savepopup_clicked" swapped="no" />
                <style>
                  <class name="suggested-action" />
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </object>
</interface>