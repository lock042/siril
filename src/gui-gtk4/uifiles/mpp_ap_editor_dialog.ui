<interface>
  <requires lib="gtk" version="4.0"/>
  <!--
    NOTE: spinners reference adjustments defined in siril.ui (adj_mpp_*).
    Sharing the same GtkAdjustment objects keeps the editor and the MPP
    register sub-panel in lock-step — the value is the source of truth,
    not the widgets bound to it. (GtkBuilder loads all .ui files into
    one flat object table, so cross-file references work.)
  -->
  <object class="GtkWindow" id="mpp_ap_editor_dialog">
    <property name="width-request">420</property>
    <property name="height-request">280</property>
    <property name="title" translatable="yes">Alignment Points Editor</property>
    <property name="resizable">0</property>
    <property name="modal">0</property>
    <signal name="close-request" handler="on_mpp_ap_editor_dialog_close_request" swapped="no"/>
    <signal name="show" handler="on_mpp_ap_editor_dialog_show" swapped="no"/>
    <signal name="hide" handler="on_mpp_ap_editor_dialog_hide" swapped="no"/>
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">10</property>
        <property name="margin-top">8</property>
        <property name="margin-bottom">8</property>
        <property name="margin-start">8</property>
        <property name="margin-end">8</property>
        <child>
          <object class="GtkGrid">
            <property name="vexpand">1</property>
            <property name="row-spacing">6</property>
            <property name="column-spacing">10</property>
            <property name="margin-top">8</property>
            <property name="margin-bottom">8</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>
            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">AP half-box width (px)</property>
                <property name="halign">end</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_ap_editor_half_box">
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <property name="adjustment">adj_mpp_half_box</property>
                <property name="numeric">1</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">Min brightness</property>
                <property name="halign">end</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_ap_editor_brightness">
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <property name="adjustment">adj_mpp_min_brightness</property>
                <property name="numeric">1</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">Min contrast</property>
                <property name="halign">end</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_ap_editor_contrast">
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <property name="adjustment">adj_mpp_min_contrast</property>
                <property name="numeric">1</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">Min structure</property>
                <property name="halign">end</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">3</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_ap_editor_structure">
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <property name="adjustment">adj_mpp_min_structure</property>
                <property name="digits">3</property>
                <property name="numeric">1</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">3</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="label_mpp_ap_editor_count">
                <property name="label" translatable="yes">Current APs: 0</property>
                <property name="halign">start</property>
                <property name="margin-top">8</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">4</property>
                  <property name="column-span">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">Mouse: left-click adds an AP, right-click removes one, click-and-drag moves an AP.</property>
                <property name="halign">start</property>
                <property name="wrap">1</property>
                <property name="max-width-chars">48</property>
                <property name="margin-top">2</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">5</property>
                  <property name="column-span">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="spacing">8</property>
                <property name="margin-top">10</property>
                <child>
                  <object class="GtkButton" id="button_mpp_ap_editor_auto_place">
                    <property name="halign">center</property>
                    <property name="label" translatable="yes">Auto-place</property>
                    <property name="focusable">1</property>
                    <property name="receives-default">1</property>
                    <property name="tooltip-text" translatable="yes">Re-run automatic AP placement on the cached reference frame using the parameters above. Replaces the entire AP grid. Per-AP frame qualities will be refreshed automatically at Register time.</property>
                    <signal name="clicked" handler="on_mpp_ap_editor_auto_place_clicked" swapped="no"/>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="button_mpp_ap_editor_clear">
                    <property name="halign">center</property>
                    <property name="label" translatable="yes">Clear all</property>
                    <property name="focusable">1</property>
                    <property name="receives-default">1</property>
                    <property name="tooltip-text" translatable="yes">Drop every AP. Per-AP frame qualities will be refreshed at Register time if any APs are added later.</property>
                    <signal name="clicked" handler="on_mpp_ap_editor_clear_clicked" swapped="no"/>
                  </object>
                </child>
                <layout>
                  <property name="column">0</property>
                  <property name="row">6</property>
                  <property name="column-span">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="check_mpp_ap_editor_show_patches">
                <property name="label" translatable="yes">Show stacking patches</property>
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="yes">Draw the larger stacking patches (dashed cyan) alongside the correlation boxes (solid yellow). Patches are 1.5× the box width and overlap each neighbour by ~25 %; that overlap is where Stage C&apos;s per-AP weighted shifts cross-fade. Persistent — outlines stay drawn whenever the AP overlay is visible, even after this dialog closes, until you uncheck.</property>
                <property name="halign">start</property>
                <property name="margin-top">8</property>
                <signal name="toggled" handler="on_mpp_ap_editor_show_patches_toggled" swapped="no"/>
                <layout>
                  <property name="column">0</property>
                  <property name="row">7</property>
                  <property name="column-span">2</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="halign">end</property>
            <property name="spacing">6</property>
            <property name="homogeneous">1</property>
            <child>
              <object class="GtkButton" id="button_mpp_ap_editor_cancel">
                <property name="label" translatable="yes">Cancel</property>
                <property name="focusable">1</property>
                <property name="receives-default">1</property>
                <property name="tooltip-text" translatable="yes">Discard the AP edits made since the dialog was opened and close. The AP grid is restored to its state at dialog-open time.</property>
                <signal name="clicked" handler="on_mpp_ap_editor_cancel_clicked" swapped="no"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="button_mpp_ap_editor_commit">
                <property name="label" translatable="yes">Commit &amp; close</property>
                <property name="focusable">1</property>
                <property name="receives-default">1</property>
                <property name="tooltip-text" translatable="yes">Keep edits and close the dialog. After committing, click Register to compute per-AP shifts using this AP grid.</property>
                <signal name="clicked" handler="on_mpp_ap_editor_commit_clicked" swapped="no"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </object>
</interface>
