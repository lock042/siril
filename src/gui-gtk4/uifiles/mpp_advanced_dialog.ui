<interface>
  <requires lib="gtk" version="4.0"/>
  <!--
    NOTE: several spinners here reference adjustments defined in
    siril_registration.ui (adj_mpp_*), which loads first — GtkBuilder keeps
    one flat object table across ui files, so the references resolve in the
    application even though standalone validation of this file reports them
    missing (same situation as mpp_ap_editor_dialog.ui). Sharing the
    adjustments also keeps this window and the AP editor in lock-step.
  -->
  <object class="GtkAdjustment" id="adj_mpp_adv_refine_frames">
    <property name="upper">500</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
  </object>
  <object class="GtkAdjustment" id="adj_mpp_adv_smooth">
    <property name="upper">10</property>
    <property name="step-increment">0.5</property>
    <property name="page-increment">1</property>
    <property name="value">2.5</property>
  </object>
  <object class="GtkWindow" id="mpp_advanced_dialog">
    <property name="title" translatable="yes">Multipoint registration — advanced settings</property>
    <property name="resizable">0</property>
    <property name="modal">0</property>
    <property name="hide-on-close">1</property>
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">10</property>
        <property name="margin-top">10</property>
        <property name="margin-bottom">10</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <child>
          <object class="GtkGrid">
            <property name="row-spacing">6</property>
            <property name="column-spacing">10</property>
            <child>
              <object class="GtkCheckButton" id="check_mpp_adv_refine">
                <property name="label" translatable="yes">Refine against a first-pass stack</property>
                <property name="focusable">1</property>
                <property name="active">1</property>
                <property name="tooltip-text" translatable="yes">After the normal registration pass, stack the best few frames of each alignment point and re-measure every shift against that much sharper reference instead of the averaged reference frame. Markedly reduces failed measurements on difficult data (e.g. solar surface detail). Default on.</property>
                <signal name="toggled" handler="on_check_mpp_adv_refine_toggled" swapped="no"/>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                  <property name="column-span">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="label_mpp_adv_refine_frames">
                <property name="halign">start</property>
                <property name="margin-start">24</property>
                <property name="label" translatable="yes">Refinement frames per point:</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_adv_refine_frames">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="yes">Used only by the refinement pass: how many of each alignment point's best-ranked frames are stacked into that point's refinement reference. (The first pass correlates against the averaged reference frame built from the globally best frames; the refinement reference is per-point and locally aligned, hence much sharper.) 0 = automatic (about 5% of the frames, limited to 8–32) — right for almost all data.</property>
                <property name="adjustment">adj_mpp_adv_refine_frames</property>
                <property name="numeric">1</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="yes">Shift smoothing radius (grid steps):</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_adv_smooth">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="yes">Smooth each frame's alignment-point shifts with a robust fit over the neighbouring points within this radius. The unit is grid steps (multiples of the alignment-point grid pitch), so the neighbourhood adapts to the grid density. Individual shift measurements carry noise well above the true frame-to-frame distortion, which varies smoothly across the image, so the fit removes most of the noise without flattening genuine distortion. 0 disables. Default 2.5.</property>
                <property name="adjustment">adj_mpp_adv_smooth</property>
                <property name="digits">1</property>
                <property name="numeric">1</property>
                <property name="value">2.5</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="check_mpp_adv_zero_mean">
                <property name="label" translatable="yes">Zero-mean correlation</property>
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="yes">Subtract the local mean brightness in the per-alignment-point correlation. Helps when transparency drifts across the capture, but where the correlation boxes hold little contrast it roughly doubles failed shift measurements and can cost detail. Default off.</property>
                <property name="halign">start</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">3</property>
                  <property name="column-span">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="1">AP search width:</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">4</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_search_width">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">Per-AP correlation search radius in pixels. Default 14.</property>
                <property name="adjustment">adj_mpp_search_width</property>
                <property name="numeric">1</property>
                <property name="value">14</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">4</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="1">Global search width:</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">5</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_search_global">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">Stage-A global alignment correlation search radius in pixels. Default 34.</property>
                <property name="adjustment">adj_mpp_search_global</property>
                <property name="numeric">1</property>
                <property name="value">34</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">5</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="1">Register percent:</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">6</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_reg_stack_percent">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">Percentage of the best frames each alignment point ranks and computes shifts for during registration. This is an upper bound on the Stack tab's Stack percent: set it at least as high as the largest fraction you'll want to stack, because you can lower the percentage at stack time but not raise it without re-registering. Lower it only to save compute (and shrink the sidecar) when you already know you won't stack more than this fraction. Default 100% — register every frame.</property>
                <property name="adjustment">adj_mpp_register_percent</property>
                <property name="numeric">1</property>
                <property name="value">100</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">6</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="1">Min brightness:</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">7</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_min_brightness">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">APs whose brightest pixel falls below this are rejected. 0..255 scale, auto-scaled for 16-bit input. Default 10.</property>
                <property name="adjustment">adj_mpp_min_brightness</property>
                <property name="numeric">1</property>
                <property name="value">10</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">7</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="1">Min contrast:</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">8</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_min_contrast">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">Minimum (max - min) over an AP box; APs below this contrast are rejected. 0..255 scale. Default 0 (off).</property>
                <property name="adjustment">adj_mpp_min_contrast</property>
                <property name="numeric">1</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">8</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="1">Min structure:</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">9</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_mpp_min_structure">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">Normalised gradient magnitude minimum (0..1) — APs with weaker structure are rejected. Default 0.04.</property>
                <property name="adjustment">adj_mpp_min_structure</property>
                <property name="digits">3</property>
                <property name="numeric">1</property>
                <property name="value">0.04</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">9</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="check_mpp_dewarp">
                <property name="label" translatable="1">Apply per-AP shifts</property>
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">When off, all APs use the same single best-frame shift instead of per-AP shifts. Default on.</property>
                <property name="halign">start</property>
                <property name="active">1</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">10</property>
                  <property name="column-span">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="check_mpp_normalize">
                <property name="label" translatable="1">Brightness-normalise quality</property>
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">Make each frame's quality score independent of exposure and transparency changes by normalising it against the frame's brightness. Default on.</property>
                <property name="halign">start</property>
                <property name="active">1</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">11</property>
                  <property name="column-span">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="check_mpp_seed">
                <property name="label" translatable="1">Seed from existing registration</property>
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">Use the sequence's existing shift registration data (if any) to pre-centre each frame's global-alignment search. Lets jumpy video whose drift exceeds the global search width align correctly. Default on; ignored when the sequence has no registration data.</property>
                <property name="halign">start</property>
                <property name="active">1</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">12</property>
                  <property name="column-span">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="yes">Colour demosaicing (stacking):</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">13</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkDropDown" id="combo_mpp_adv_debayer">
                <property name="tooltip-text" translatable="yes">Demosaicing algorithm used when stacking colour (Bayer) videos; stored with the registration and applied at stacking time. LMMSE (default) gives the cleanest stacked colour on noisy captures; luminance detail is the same for all choices.</property>
                <property name="model">
                  <object class="GtkStringList">
                    <items>
                      <item translatable="yes">Bilinear</item>
                      <item translatable="yes">VNG</item>
                      <item translatable="yes">AHD</item>
                      <item translatable="yes">AMaZE</item>
                      <item translatable="yes">DCB</item>
                      <item translatable="yes">HPHD</item>
                      <item translatable="yes">IGV</item>
                      <item translatable="yes">LMMSE</item>
                      <item translatable="yes">RCD</item>
                    </items>
                  </object>
                </property>
                <property name="selected">7</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">13</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="yes">Stacking engine:</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">14</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkDropDown" id="combo_mpp_adv_engine">
                <property name="tooltip-text" translatable="yes">How the aligned frames are combined; stored with the registration and applied at stacking time. Patch mosaic stacks each alignment point's patch at its own shift and blends the overlaps — the robust default. Warp field resamples each whole frame once through a smooth deformation interpolated between the alignment points: sharper on planetary discs, equal elsewhere, but slower on large images.</property>
                <property name="model">
                  <object class="GtkStringList">
                    <items>
                      <item translatable="yes">Patch mosaic</item>
                      <item translatable="yes">Warp field</item>
                    </items>
                  </object>
                </property>
                <property name="selected">0</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">14</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="button_mpp_adv_reset">
            <property name="label" translatable="yes">Reset to defaults</property>
            <property name="focusable">1</property>
            <property name="halign">end</property>
            <property name="tooltip-text" translatable="yes">Restore every setting in this window to its default value.</property>
            <signal name="clicked" handler="on_mpp_advanced_reset_clicked" swapped="no"/>
          </object>
        </child>
      </object>
    </property>
  </object>
</interface>
