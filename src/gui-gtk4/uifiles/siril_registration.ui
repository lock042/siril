<?xml version='1.0' encoding='UTF-8'?>
<interface>
  <requires lib="gtk" version="4.0" />
  <object class="GtkScrolledWindow" id="registration_tab">
    <property name="focusable">1</property>
    <property name="hscrollbar-policy">never</property>
    <property name="child">
      <object class="GtkViewport">
        <property name="child">
          <object class="GtkBox" id="vboxreg">
            <property name="orientation">vertical</property>
            <property name="spacing">10</property>
            <child>
              <object class="GtkExpander" id="autoreg_expander">
                <property name="focusable">1</property>
                <property name="expanded">1</property>
                <child>
                  <object class="GtkBox">
                    <property name="margin-top">5</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">5</property>
                    <child>
                      <object class="GtkFrame">
                        <property name="child">
                          <object class="GtkBox">
                            <property name="margin-top">6</property>
                            <property name="orientation">vertical</property>
                            <property name="spacing">5</property>
                            <child>
                              <object class="GtkDropDown" id="comboboxregmethod">
                                <signal name="notify::selected" handler="on_comboboxregmethod_changed" swapped="no" />
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox">
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="1">Registration channel: </property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkDropDown" id="comboboxreglayer">
                                    <property name="tooltip-text" translatable="1">Layer on which the registration is done. It can only be done on one layer at a time, so on monochrome images.
The (*) sign appearing after the layer's name means that registration data is already available for this layer.
When processing images, registration data is taken from the default layer if available (for RGB images: Green, else fallback to Blue then Red).</property>
                                    <signal name="notify::selected" handler="on_comboboxreglayer_changed" swapped="no" />
                                  </object>
                                </child>
                                <child>
                                  <placeholder />
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkNotebook" id="notebook_registration">
                                <property name="valign">start</property>
                                <property name="margin-top">10</property>
                                <property name="show-tabs">0</property>
                                <property name="show-border">0</property>
                                <child>
                                  <object class="GtkNotebookPage">
                                    <property name="child">
                                      <object class="GtkGrid" id="global_page">
                                        <property name="margin-start">6</property>
                                        <property name="margin-end">6</property>
                                        <property name="margin-start">6</property>
                                        <property name="margin-end">6</property>
                                        <property name="margin-top">6</property>
                                        <property name="margin-bottom">6</property>
                                        <property name="row-spacing">5</property>
                                        <property name="column-spacing">5</property>
                                        <child>
                                          <object class="GtkCheckButton" id="checkStarSelect">
                                            <property name="label" translatable="1">Match stars in selection</property>
                                            <property name="focusable">1</property>
                                            <property name="tooltip-markup" translatable="1">Check this box if you want to perform the Global Star Alignment algorithm within the selected area in the reference image. If no selection are done, this option is ignored.

&lt;b&gt;WARNING&lt;/b&gt;: Make sure to draw a selection with a sufficient number of stars.</property>
                                            <property name="halign">start</property>
                                            <layout>
                                              <property name="column">2</property>
                                              <property name="row">2</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="halign">start</property>
                                            <property name="label" translatable="1">Minimum Star Pairs:</property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">1</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkSpinButton" id="spinbut_minpairs">
                                            <property name="focusable">1</property>
                                            <property name="tooltip-text" translatable="1">The minimum number of star pairs a given frame can have in relation with the reference frame. If a given light frame has less star pairs, it will not be registered.</property>
                                            <property name="width-chars">4</property>
                                            <property name="max-width-chars">4</property>
                                            <property name="text">10</property>
                                            <property name="adjustment">register_minpairs</property>
                                            <property name="numeric">1</property>
                                            <property name="value">10</property>
                                            <style>
                                              <class name="small-spinbutton" />
                                            </style>
                                            <layout>
                                              <property name="column">1</property>
                                              <property name="row">1</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="halign">start</property>
                                            <property name="label" translatable="1">Maximum Stars Fitted:</property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">2</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkDropDown" id="comboreg_maxstars">
                                            <property name="model">
                                              <object class="GtkStringList">
                                                <items>
                                                  <item>100</item>
                                                  <item>200</item>
                                                  <item translatable="yes">500</item>
                                                  <item>1000</item>
                                                  <item>2000</item>
                                                </items>
                                              </object>
                                            </property>
                                            <property name="tooltip-text" translatable="1">The maximum number of stars to be searched for in each frame (default 2000). The larger this value, the more stars will potentially be detected, resulting in a longer detection but more accurate registration.</property>
                                            <property name="selected">4</property>
                                            <layout>
                                              <property name="column">1</property>
                                              <property name="row">2</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkDropDown" id="comboreg_transfo">
                                            <property name="model">
                                              <object class="GtkStringList">
                                                <items>
                                                  <item translatable="yes">Shift</item>
                                                  <item translatable="yes">Similarity</item>
                                                  <item translatable="yes">Affine</item>
                                                  <item translatable="yes">Homography</item>
                                                </items>
                                              </object>
                                            </property>
                                            <property name="tooltip-markup" translatable="1">&lt;b&gt;Shift&lt;/b&gt; is a 2 degree-of-freedom (x/y shifts) rigid mapping, well-suited for images with no distortion, no scaling and no field rotation. It needs at least 1 pair of stars to be matched to define the transformation.

&lt;b&gt;Similarity&lt;/b&gt; is a 4 degree-of-freedom (one scale, one rotation and x/y shifts) more rigid mapping than homography, well-suited for images with no distortion. It needs at least 2 pairs of stars to be matched to define the transformation.

&lt;b&gt;Affine&lt;/b&gt; is a 6 degree-of-freedom (two scales, one shear, one rotation and x/y shifts) more rigid mapping than homography, well-suited for images with little distortion. It needs at least 3 pairs of stars to be matched to define the transformation.

&lt;b&gt;Homography&lt;/b&gt; is the default transformation which uses an 8-degree-of-freedom transform to warp the images onto the reference frame. This is well-suited for the general case and strongly recommended for wide-field images. It needs at least 4 pairs of stars to be matched to define the transformation.

&lt;b&gt;WARNING&lt;/b&gt;: The initial star matching uses triangle similarity algorithm, in consequence the minimum of star pairs must be at least of 3 for &lt;b&gt;Shift&lt;/b&gt;, &lt;b&gt;Similarity&lt;/b&gt; and &lt;b&gt;Affine&lt;/b&gt; and of 4 for &lt;b&gt;Homography&lt;/b&gt;.</property>
                                            <property name="selected">3</property>
                                            <signal name="notify::selected" handler="on_comboreg_transfo_changed" swapped="no" />
                                            <layout>
                                              <property name="column">1</property>
                                              <property name="row">0</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="halign">start</property>
                                            <property name="label" translatable="1">Transformation:</property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">0</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkButton">
                                            <property name="focusable">1</property>
                                            <property name="receives-default">1</property>
                                            <property name="tooltip-text" translatable="1">Hit this button for star detection settings</property>
                                            <property name="halign">start</property>
                                            <property name="action-name">win.dyn-psf</property>
                                            <child>
                                              <object class="GtkImage">
                                                <property name="icon-name">applications-system-symbolic</property>
                                              </object>
                                            </child>
                                            <layout>
                                              <property name="column">2</property>
                                              <property name="row">1</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkCheckButton" id="reg_2pass">
                                            <property name="label" translatable="1">2pass registration</property>
                                            <property name="focusable">1</property>
                                            <property name="tooltip-markup" translatable="1">When this box is checked, the transformed images are not saved as a newly registered sequence. The transformation matrices are saved to the sequence file. The registration data can then be inspected and some images unselected, prior to applying the transformations using the Apply Existing Registration method.

When this box is unchecked, the global star registration will be calculated and immediately applied using the output registration options selected below.</property>
                                            <property name="halign">end</property>
                                            <signal name="toggled" handler="on_reg_2pass_toggled" swapped="no" />
                                            <layout>
                                              <property name="column">3</property>
                                              <property name="row">0</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkGrid" id="grid_reg_wcs">
                                            <property name="row-spacing">5</property>
                                            <property name="column-spacing">5</property>
                                            <child>
                                              <object class="GtkLabel">
                                                <property name="halign">start</property>
                                                <property name="label" translatable="1">Undistortion:</property>
                                                <layout>
                                                  <property name="column">0</property>
                                                  <property name="row">0</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkDropDown" id="comboreg_undistort">
                                                <property name="model">
                                                  <object class="GtkStringList">
                                                    <items>
                                                      <item translatable="yes">None</item>
                                                      <item translatable="yes">From image</item>
                                                      <item translatable="yes">From FITS/WCS file</item>
                                                      <item translatable="yes">From distortion masters</item>
                                                    </items>
                                                  </object>
                                                </property>
                                                <property name="tooltip-markup" translatable="1">To correct images for distortions, you can either select:
- distortion solution from current platesolved image
- distortion solution from an existing WCS file
- distortion solution from distortions masters</property>
                                                <property name="selected">0</property>
                                                <signal name="notify::selected" handler="on_comboreg_undistort_changed" swapped="no" />
                                                <layout>
                                                  <property name="column">1</property>
                                                  <property name="row">0</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkBox" id="reg_wcsfilechooser_box">
                                                <child>
                                                  <object class="GtkEntry" id="reg_wcsfile_entry">
                                                    <property name="focusable">1</property>
                                                    <property name="tooltip-text" translatable="1">Select a file to read distortion information from:
- a FITS file which has been platesolved with distortion.
- a wcs file which was written by a previous registration with distortions.</property>
                                                    <property name="hexpand">1</property>
                                                    <property name="input-hints">GTK_INPUT_HINT_NO_EMOJI | GTK_INPUT_HINT_NONE</property>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkButton" id="reg_wcsfile_button">
                                                    <property name="focusable">1</property>
                                                    <property name="tooltip-text" translatable="1">The bias/offset master image will be removed from all images in the sequence.</property>
                                                    <property name="halign">start</property>
                                                    <property name="use-underline">1</property>
                                                    <signal name="clicked" handler="on_reg_wcsfile_button_clicked" swapped="no" />
                                                    <child>
                                                      <object class="GtkImage">
                                                        <property name="icon-name">document-open-symbolic</property>
                                                      </object>
                                                    </child>
                                                  </object>
                                                </child>
                                                <layout>
                                                  <property name="column">1</property>
                                                  <property name="row">1</property>
                                                  <property name="column-span">3</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <placeholder />
                                            </child>
                                            <child>
                                              <placeholder />
                                            </child>
                                            <child>
                                              <placeholder />
                                            </child>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">3</property>
                                              <property name="column-span">4</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <placeholder />
                                        </child>
                                        <child>
                                          <placeholder />
                                        </child>
                                        <child>
                                          <placeholder />
                                        </child>
                                      </object>
                                    </property>
                                    <property name="tab">
                                      <object class="GtkLabel">
                                        <property name="valign">start</property>
                                        <property name="label">page 1</property>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkNotebookPage">
                                    <property name="position">1</property>
                                    <property name="tab-fill">False</property>
                                    <property name="child">
                                      <object class="GtkBox" id="comet_page">
                                        <property name="valign">start</property>
                                        <property name="margin-start">6</property>
                                        <property name="margin-end">6</property>
                                        <property name="margin-start">6</property>
                                        <property name="margin-end">6</property>
                                        <property name="margin-top">6</property>
                                        <property name="margin-bottom">7</property>
                                        <property name="orientation">vertical</property>
                                        <property name="spacing">5</property>
                                        <child>
                                          <object class="GtkGrid">
                                            <property name="row-spacing">5</property>
                                            <property name="column-spacing">5</property>
                                            <property name="column-homogeneous">1</property>
                                            <child>
                                              <object class="GtkBox">
                                                <child>
                                                  <object class="GtkLabel">
                                                    <property name="hexpand">1</property>
                                                    <property name="tooltip-text" translatable="1">Comet velocity in pixel per hour.</property>
                                                    <property name="halign">end</property>
                                                    <property name="label" translatable="1">Velocity: </property>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkLabel" id="label1_comet">
                                                    <property name="hexpand">1</property>
                                                    <property name="tooltip-text" translatable="1">Comet velocity in pixel per hour.</property>
                                                    <property name="halign">start</property>
                                                    <property name="label">Δx: 0.00, Δy: 0.00</property>
                                                  </object>
                                                </child>
                                                <layout>
                                                  <property name="column">0</property>
                                                  <property name="row">3</property>
                                                  <property name="column-span">3</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton" id="button1_comet">
                                                <property name="label" translatable="1">Pick object in #1</property>
                                                <property name="focusable">1</property>
                                                <property name="receives-default">1</property>
                                                <property name="tooltip-text" translatable="1">Select an area around the asteroid or the comet core in the first selected image, then click on this button. The pixel coordinates of the object will be computed and displayed.</property>
                                                <signal name="clicked" handler="on_button_comet_clicked" swapped="no" />
                                                <layout>
                                                  <property name="column">0</property>
                                                  <property name="row">0</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton" id="button2_comet">
                                                <property name="label" translatable="1">Pick object in #2</property>
                                                <property name="focusable">1</property>
                                                <property name="receives-default">1</property>
                                                <property name="tooltip-text" translatable="1">Select an area around the asteroid or the comet core in the last selected image, then click on this button. The pixel coordinates of the object will be computed and displayed.</property>
                                                <signal name="clicked" handler="on_button_comet_clicked" swapped="no" />
                                                <layout>
                                                  <property name="column">0</property>
                                                  <property name="row">1</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkEntry" id="entry1_x_comet">
                                                <property name="focusable">1</property>
                                                <property name="tooltip-text" translatable="1">Core X-coordinates of the first image.</property>
                                                <property name="width-chars">7</property>
                                                <property name="text">0.00</property>
                                                <property name="input-purpose">number</property>
                                                <property name="input-hints">GTK_INPUT_HINT_NO_EMOJI | GTK_INPUT_HINT_NONE</property>
                                                <signal name="changed" handler="on_entry_comet_changed" swapped="no" />
                                                <layout>
                                                  <property name="column">1</property>
                                                  <property name="row">0</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkEntry" id="entry2_x_comet">
                                                <property name="focusable">1</property>
                                                <property name="tooltip-text" translatable="1">Core X-coordinates of the second image.</property>
                                                <property name="width-chars">7</property>
                                                <property name="text">0.00</property>
                                                <property name="input-purpose">number</property>
                                                <property name="input-hints">GTK_INPUT_HINT_NO_EMOJI | GTK_INPUT_HINT_NONE</property>
                                                <signal name="changed" handler="on_entry_comet_changed" swapped="no" />
                                                <layout>
                                                  <property name="column">1</property>
                                                  <property name="row">1</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkEntry" id="entry1_y_comet">
                                                <property name="focusable">1</property>
                                                <property name="tooltip-text" translatable="1">Core Y-coordinates of the first image.</property>
                                                <property name="width-chars">7</property>
                                                <property name="text">0.00</property>
                                                <property name="input-purpose">number</property>
                                                <signal name="changed" handler="on_entry_comet_changed" swapped="no" />
                                                <layout>
                                                  <property name="column">2</property>
                                                  <property name="row">0</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkEntry" id="entry2_y_comet">
                                                <property name="focusable">1</property>
                                                <property name="tooltip-text" translatable="1">Core Y-coordinates of the second image.</property>
                                                <property name="width-chars">7</property>
                                                <property name="text">0.00</property>
                                                <property name="input-purpose">number</property>
                                                <signal name="changed" handler="on_entry_comet_changed" swapped="no" />
                                                <layout>
                                                  <property name="column">2</property>
                                                  <property name="row">1</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <placeholder />
                                            </child>
                                            <child>
                                              <placeholder />
                                            </child>
                                            <child>
                                              <placeholder />
                                            </child>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkGrid">
                                            <property name="row-spacing">5</property>
                                            <property name="column-spacing">5</property>
                                            <child>
                                              <object class="GtkLabel">
                                                <property name="tooltip-text" translatable="1">Comet velocity in pixel per hour.</property>
                                                <property name="halign">end</property>
                                                <property name="label" translatable="1">Prefix: </property>
                                                <layout>
                                                  <property name="column">0</property>
                                                  <property name="row">0</property>
                                                </layout>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkEntry" id="cometseqname_entry">
                                                <property name="focusable">1</property>
                                                <property name="tooltip-text" translatable="1">Prefix of the sequence resulting from the registration. Only the seq file is created, not new images.</property>
                                                <property name="max-length">10</property>
                                                <property name="width-chars">10</property>
                                                <property name="text">comet_</property>
                                                <property name="input-hints">GTK_INPUT_HINT_NO_EMOJI | GTK_INPUT_HINT_NONE</property>
                                                <layout>
                                                  <property name="column">1</property>
                                                  <property name="row">0</property>
                                                </layout>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                      </object>
                                    </property>
                                    <property name="tab">
                                      <object class="GtkLabel">
                                        <property name="valign">start</property>
                                        <property name="label">page 2</property>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkNotebookPage">
                                    <property name="position">2</property>
                                    <property name="tab-fill">False</property>
                                    <property name="child">
                                      <object class="GtkBox" id="123star_page">
                                        <property name="valign">start</property>
                                        <property name="margin-start">6</property>
                                        <property name="margin-end">6</property>
                                        <property name="margin-start">6</property>
                                        <property name="margin-end">6</property>
                                        <property name="margin-top">6</property>
                                        <property name="margin-bottom">6</property>
                                        <property name="orientation">vertical</property>
                                        <child>
                                          <object class="GtkBox">
                                            <property name="spacing">5</property>
                                            <child>
                                              <object class="GtkButton" id="pickstar1">
                                                <property name="label" translatable="1">Pick 1st star</property>
                                                <property name="focusable">1</property>
                                                <property name="receives-default">1</property>
                                                <property name="valign">center</property>
                                                <signal name="clicked" handler="on_select_star_button_clicked" swapped="no" />
                                                <style>
                                                  <class name="suggested-action" />
                                                </style>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton" id="pickstar2">
                                                <property name="label" translatable="1">Pick 2nd star</property>
                                                <property name="focusable">1</property>
                                                <property name="receives-default">1</property>
                                                <property name="valign">center</property>
                                                <signal name="clicked" handler="on_select_star_button_clicked" swapped="no" />
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton" id="pickstar3">
                                                <property name="label" translatable="1">Pick 3rd star</property>
                                                <property name="focusable">1</property>
                                                <property name="receives-default">1</property>
                                                <property name="valign">center</property>
                                                <signal name="clicked" handler="on_select_star_button_clicked" swapped="no" />
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkGrid">
                                                <property name="row-spacing">5</property>
                                                <property name="column-spacing">5</property>
                                                <child>
                                                  <object class="GtkLabel">
                                                    <property name="label" translatable="1">Star #1:</property>
                                                    <layout>
                                                      <property name="column">0</property>
                                                      <property name="row">0</property>
                                                    </layout>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkLabel">
                                                    <property name="label" translatable="1">Star #2:</property>
                                                    <layout>
                                                      <property name="column">0</property>
                                                      <property name="row">1</property>
                                                    </layout>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkLabel">
                                                    <property name="label" translatable="1">Star #3:</property>
                                                    <layout>
                                                      <property name="column">0</property>
                                                      <property name="row">2</property>
                                                    </layout>
                                                  </object>
                                                </child>
                                                <child>
