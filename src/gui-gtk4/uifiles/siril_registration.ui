                                <child>
                                  <object class="GtkLabel" id="estimate_label">
                                    <property name="halign">start</property>
                                    <property name="valign">center</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">1</property>
                                    </layout>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox">
                                <property name="halign">start</property>
                                <property name="spacing">6</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="halign">start</property>
                                    <property name="label" translatable="1">Scaling:</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkSpinButton" id="reg_scaling_spin">
                                    <property name="focusable">1</property>
                                    <property name="tooltip-text" translatable="1">Scaling of the output images. Use Estimate button to determine the final image size.</property>
                                    <property name="halign">end</property>
                                    <property name="width-chars">6</property>
                                    <property name="max-width-chars">5</property>
                                    <property name="text">1.00</property>
                                    <property name="adjustment">adjustment_scaling</property>
                                    <property name="climb-rate">0.10</property>
                                    <property name="digits">2</property>
                                    <property name="numeric">1</property>
                                    <property name="value">1</property>
                                    <style>
                                      <class name="small-spinbutton" />
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <placeholder />
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkStackSwitcher" id="interp_drizzle_stack_switcher">
                                <property name="tooltip-text" translatable="1">Choose whether to use an interpolation algorithm or Drizzle to apply registration</property>
                                <property name="stack">interp_drizzle_stack</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkStack" id="interp_drizzle_stack">
                                <property name="transition-type">slide-up-down</property>
                                <child>
                                  <object class="GtkStackPage">
                                    <property name="name">page0</property>
                                    <property name="title" translatable="1">Use interpolation</property>
                                    <property name="child">
                                      <object class="GtkGrid" id="grid_interp_controls">
                                        <property name="name">grid_interp_controls</property>
                                        <property name="row-spacing">6</property>
                                        <property name="column-spacing">6</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="halign">start</property>
                                            <property name="label" translatable="1">Algorithm: </property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">0</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkDropDown" id="ComboBoxRegInter">
                                            <property name="model">
                                              <object class="GtkStringList">
                                                <items>
                                                  <item translatable="yes">Nearest Neighbor</item>
                                                  <item translatable="yes">Bilinear</item>
                                                  <item translatable="yes">Bicubic</item>
                                                  <item translatable="yes">Pixel Area Relation</item>
                                                  <item translatable="yes">Lanczos-4</item>
                                                  <item translatable="yes">None</item>
                                                </items>
                                              </object>
                                            </property>
                                            <property name="tooltip-text" translatable="1">Set the interpolation algorithm</property>
                                            <property name="halign">start</property>
                                            <property name="valign">center</property>
                                            <property name="selected">3</property>
                                            <signal name="notify::selected" handler="on_ComboBoxRegInter_changed" swapped="no" />
                                            <layout>
                                              <property name="column">1</property>
                                              <property name="row">0</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkCheckButton" id="toggle_reg_clamp">
                                            <property name="label" translatable="1">Interpolation clamping</property>
                                            <property name="focusable">1</property>
                                            <property name="tooltip-text" translatable="1">Activates clamping of the Bicubic and Lancsoz4 interpolation algorithms

The main issue with Lanczos and Bicubic interpolation algorithms is the generation of strong undershot artifacts (ringing). These artifacts are caused by the negative lobes of the interpolation functions falling on high contrast edges and isolated bright pixels (like in the stars). This usually only occurs with linear data.

In current Siril implementations, we have included a clamping mechanism that prevents negative interpolated values and ringing artifacts for most images.</property>
                                            <property name="halign">start</property>
                                            <property name="active">1</property>
                                            <signal name="toggled" handler="on_toggle_reg_clamp_toggled" swapped="no" />
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">1</property>
                                              <property name="column-span">2</property>
                                            </layout>
                                          </object>
                                        </child>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkStackPage">
                                    <property name="name">page1</property>
                                    <property name="title" translatable="1">Use drizzle</property>
                                    <property name="child">
                                      <object class="GtkGrid" id="grid_drizzle_controls">
                                        <property name="name">grid_drizzle_controls</property>
                                        <property name="row-spacing">6</property>
                                        <property name="column-spacing">6</property>
                                        <child>
                                          <object class="GtkCheckButton" id="driz_use_flats">
                                            <property name="label" translatable="1">Include master flat in initial pixel weighting</property>
                                            <property name="focusable">1</property>
                                            <property name="tooltip-text" translatable="1">Check this to include the master flat in the initial pixel weighting. This will result in pixels from less vignetted areas of input frames being weighted more heavily than pixels from more vignetted areas, where they land on the same output pixel. This is at best a minor gain.

The master flat must be set in the Calibration tab.</property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">2</property>
                                              <property name="column-span">3</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="halign">start</property>
                                            <property name="label" translatable="1">Droplet Model</property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">1</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="halign">start</property>
                                            <property name="label" translatable="1">Pixel Fraction</property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">0</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkDropDown" id="combo_driz_kernel">
                                            <property name="model">
                                              <object class="GtkStringList">
                                                <items>
                                                  <item translatable="yes">Square</item>
                                                  <item translatable="yes">Gaussian</item>
                                                  <item translatable="yes">Point</item>
                                                  <item translatable="yes">Turbo</item>
                                                  <item translatable="yes">Lanczos2</item>
                                                  <item translatable="yes">Lanczos3</item>
                                                </items>
                                              </object>
                                            </property>
                                            <property name="tooltip-text" translatable="1">Select the droplet model. See the documentation for details of when to use each model.</property>
                                            <property name="selected">0</property>
                                            <layout>
                                              <property name="column">1</property>
                                              <property name="row">1</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkSpinButton" id="spin_driz_dropsize">
                                            <property name="focusable">1</property>
                                            <property name="tooltip-text" translatable="1">Sets the droplet size as a fraction of the input pixel size. Typically a good value for this is the reciprocal of the drizzle scale.</property>
                                            <property name="text">1.00</property>
                                            <property name="adjustment">adj_driz_dropsize</property>
                                            <property name="digits">5</property>
                                            <property name="value">1</property>
                                            <layout>
                                              <property name="column">1</property>
                                              <property name="row">0</property>
                                            </layout>
                                          </object>
                                        </child>
                                        <child>
                                          <placeholder />
                                        </child>
                                        <child>
                                          <placeholder />
                                        </child>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox">
                                <property name="spacing">6</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="1">Prefix:</property>
                                    <property name="justify">center</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkEntry" id="regseqname_entry">
                                    <property name="focusable">1</property>
                                    <property name="tooltip-text" translatable="1">Prefix of the image names resulting from the registration.</property>
                                    <property name="max-length">10</property>
                                    <property name="width-chars">10</property>
                                    <property name="text">r_</property>
                                    <property name="input-hints">GTK_INPUT_HINT_NO_EMOJI | GTK_INPUT_HINT_NONE</property>
                                  </object>
                                </child>
                                <child>
                                  <placeholder />
                                </child>
                              </object>
                            </child>
                          </object>
                        </property>
                        <child type="label">
                          <object class="GtkLabel">
                            <property name="label" translatable="1">Output registration:</property>
                            <attributes>
                              <attribute name="weight" value="bold" />
                            </attributes>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="goregister_button">
                        <property name="valign">center</property>
                        <property name="label" translatable="1">Go register</property>
                        <property name="sensitive">0</property>
                        <property name="focusable">1</property>
                        <property name="receives-default">1</property>
                        <property name="tooltip-text" translatable="1">Start the registration process. It will register images in the loaded sequence using the selected method and reference layer (loaded in the 'Image sequences' tab, current sequence name is at the bottom of the window too).</property>
                        <property name="use-underline">1</property>
                        <signal name="clicked" handler="on_seqregister_button_clicked" swapped="no" />
                        <style>
                          <class name="suggested-action" />
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="labelregisterinfo">
                        <property name="halign">end</property>
                        <property name="label" translatable="1">Load a sequence first</property>
                        <style>
                          <class name="label-info" />
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="label">
                  <object class="GtkLabel">
                    <property name="label" translatable="1">Automatic image registration</property>
                    <attributes>
                      <attribute name="weight" value="bold" />
                    </attributes>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkExpander" id="manualreg_expander">
                <property name="vexpand">1</property>
                <property name="focusable">1</property>
                <child>
                  <object class="GtkBox">
                    <property name="vexpand">1</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">10</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <child>
                          <object class="GtkBox">
                            <child>
                              <object class="GtkCheckButton" id="checkbutton_displayref">
                                <property name="label" translatable="1">Display reference image</property>
                                <property name="sensitive">0</property>
                                <property name="focusable">1</property>
                                <property name="tooltip-text" translatable="1">Display the reference image over the current image using a 50% transparency.
To be enabled, the reference image must have been explicitly set and already displayed once on the selected registration layer.</property>
                                <signal name="toggled" handler="on_checkbutton_displayref_toggled" swapped="no" />
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="labelRegRef">
                                <property name="label" translatable="1">Set reference image first</property>
                                <style>
                                  <class name="label-info" />
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox">
                            <property name="vexpand">1</property>
                            <property name="halign">center</property>
                            <property name="spacing">10</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="tooltip-text" translatable="1">Change this value, using mouse wheel or up and down arrows, to align the image with the reference image on the X axis.</property>
                                <property name="label" translatable="1">X translation:</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkSpinButton" id="spinbut_shiftx">
                                <property name="focusable">1</property>
                                <property name="width-chars">4</property>
                                <property name="max-width-chars">3</property>
                                <property name="text">0</property>
                                <property name="adjustment">adjustment_shiftx</property>
                                <property name="numeric">1</property>
                                <signal name="value-changed" handler="on_spinbut_shift_value_change" swapped="no" />
                                <style>
                                  <class name="small-spinbutton" />
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel">
                                <property name="tooltip-text" translatable="1">Change this value, using mouse wheel or up and down arrows, to align the image with the reference image on the Y axis.</property>
                                <property name="label" translatable="1">Y translation:</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkSpinButton" id="spinbut_shifty">
                                <property name="focusable">1</property>
                                <property name="width-chars">4</property>
                                <property name="max-width-chars">3</property>
                                <property name="text">0</property>
                                <property name="adjustment">adjustment_shifty</property>
                                <property name="numeric">1</property>
                                <signal name="value-changed" handler="on_spinbut_shift_value_change" swapped="no" />
                                <style>
                                  <class name="small-spinbutton" />
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="vexpand">1</property>
                        <property name="margin-top">5</property>
                        <property name="spacing">2</property>
                        <child>
                          <object class="GtkBox">
                            <property name="hexpand">1</property>
                            <property name="orientation">vertical</property>
                            <property name="spacing">5</property>
                            <child>
                              <object class="GtkToggleButton" id="toggle_reg_manual1">
                                <property name="valign">center</property>
                                <property name="label" translatable="1">Set first preview</property>
                                <property name="focusable">1</property>
                                <property name="receives-default">1</property>
                                <property name="tooltip-text" translatable="1">Allows a preview area to be displayed just below. After clicking on this button, click on the image to position the preview area's centre</property>
                                <property name="halign">center</property>
                                <signal name="toggled" handler="on_toggle_preview_toggled" swapped="no" />
                              </object>
                            </child>
                            <child>
                              <object class="GtkDrawingArea" id="drawingarea_reg_manual_preview1">
                                <property name="vexpand">1</property>
                                <property name="height-request">200</property>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox">
                            <property name="hexpand">1</property>
                            <property name="orientation">vertical</property>
                            <property name="spacing">5</property>
                            <child>
                              <object class="GtkToggleButton" id="toggle_reg_manual2">
                                <property name="valign">center</property>
                                <property name="label" translatable="1">Set second preview</property>
                                <property name="focusable">1</property>
                                <property name="receives-default">1</property>
                                <property name="tooltip-text" translatable="1">Allows a preview area to be displayed just below. After clicking on this button, click on the image to position the preview area's centre</property>
                                <property name="halign">center</property>
                                <signal name="toggled" handler="on_toggle_preview_toggled" swapped="no" />
                              </object>
                            </child>
                            <child>
                              <object class="GtkDrawingArea" id="drawingarea_reg_manual_preview2">
                                <property name="vexpand">1</property>
                                <property name="height-request">200</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="label">
                  <object class="GtkLabel">
                    <property name="label" translatable="1">Manual registration</property>
                    <attributes>
                      <attribute name="weight" value="bold" />
                    </attributes>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
  </object>
  <object class="GtkLabel" id="label28">
    <property name="tooltip-text" translatable="1">Registration is basically aligning the images from a sequence to be able to process them afterwards.</property>
    <property name="margin-top">2</property>
    <property name="margin-bottom">2</property>
    <property name="label" translatable="1">Registration</property>
    <property name="justify">center</property>
  </object>
</interface>
