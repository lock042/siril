<?xml version='1.0' encoding='UTF-8'?>
<interface>
  <requires lib="gtk" version="4.0" />
  <object class="GtkAdjustment" id="adj_clahe_clip">
    <property name="lower">0.01</property>
    <property name="upper">50</property>
    <property name="value">2</property>
    <property name="step-increment">0.10</property>
    <property name="page-increment">1</property>
  </object>
  <object class="GtkAdjustment" id="adj_clahe_size">
    <property name="lower">1</property>
    <property name="upper">128</property>
    <property name="value">8</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
  </object>
  <object class="GtkWindow" id="CLAHE_dialog">
    <property name="width-request">400</property>
    <property name="height-request">200</property>
    <property name="title" translatable="1">Contrast-Limited Adaptive Histogram Equalization...</property>
    <property name="resizable">0</property>
    <property name="default-width">400</property>
    <signal name="close-request" handler="on_CLAHE_dialog_close" swapped="no" />
    <signal name="close-request" handler="on_clahe_cancel_clicked" swapped="no" />
    <signal name="close-request" handler="siril_widget_hide_on_delete" swapped="no" />
    <signal name="show" handler="on_CLAHE_dialog_show" swapped="no" />
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox">
            <property name="margin-start">6</property>
            <property name="margin-end">6</property>
            <property name="margin-top">6</property>
            <property name="margin-bottom">6</property>
            <property name="orientation">vertical</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkBox">
                <child>
                  <object class="GtkLabel" id="label18">
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Tiles Grid Size</property>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="clahe_tiles_size_spin">
                    <property name="focusable">1</property>
                    <property name="hexpand">0</property>
                    <property name="width-chars">3</property>
                    <property name="adjustment">adj_clahe_size</property>
                    <property name="numeric">1</property>
                    <property name="value">8</property>
                    <signal name="value-changed" handler="on_clahe_tiles_size_spin_value_changed" swapped="no" />
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkScale">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">Sets size of grid for histogram equalization. Input image will be divided into equally sized rectangular tiles. </property>
                <property name="adjustment">adj_clahe_size</property>
                <property name="round-digits">1</property>
                <property name="digits">0</property>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <child>
                  <object class="GtkLabel" id="label11">
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Clip Limit</property>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_clahe">
                    <property name="focusable">1</property>
                    <property name="adjustment">adj_clahe_clip</property>
                    <property name="digits">2</property>
                    <signal name="value-changed" handler="on_spin_clahe_value_changed" swapped="no" />
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkScale" id="scale_clahe">
                <property name="focusable">1</property>
                <property name="tooltip-text" translatable="1">Sets threshold for contrast limiting.</property>
                <property name="hexpand">1</property>
                <property name="adjustment">adj_clahe_clip</property>
                <property name="round-digits">2</property>
                <property name="digits">2</property>
                <property name="value-pos">bottom</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="label_clahe">
                <property name="label" translatable="1" comments="Try to have 3 lines here.">Please, make sure to remove all black borders or other
    stacking residuals by cropping the image. If you don't,
    artifacts may appear.</property>
                <property name="wrap">1</property>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="clahe_preview">
                <property name="label" translatable="1">Preview</property>
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <property name="active">1</property>
                <signal name="toggled" handler="on_clahe_preview_toggled" swapped="no" />
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="margin-top">12</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>
            <property name="margin-bottom">12</property>
            <property name="spacing">6</property>
            <property name="halign">end</property>
            <property name="orientation">horizontal</property>
            <child>
              <object class="GtkButton" id="clahe_undo">
                <property name="label" translatable="1">Reset</property>
                <property name="focusable">1</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_clahe_undo_clicked" swapped="no" />
              </object>
            </child>
            <child>
              <object class="GtkButton" id="clahe_cancel">
                <property name="label" translatable="1">Cancel</property>
                <property name="focusable">1</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_clahe_cancel_clicked" swapped="no" />
              </object>
            </child>
            <child>
              <object class="GtkButton" id="clahe_Apply">
                <property name="label" translatable="1">Apply</property>
                <property name="focusable">1</property>
                <property name="receives-default">1</property>
                <signal name="clicked" handler="on_clahe_Apply_clicked" swapped="no" />
                <style>
                  <class name="suggested-action" />
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </object>
</interface>