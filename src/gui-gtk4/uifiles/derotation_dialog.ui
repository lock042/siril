<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkAdjustment" id="adj_derot_cx">
    <property name="lower">0</property><property name="upper">20000</property>
    <property name="step-increment">1</property><property name="page-increment">10</property>
  </object>
  <object class="GtkAdjustment" id="adj_derot_cy">
    <property name="lower">0</property><property name="upper">20000</property>
    <property name="step-increment">1</property><property name="page-increment">10</property>
  </object>
  <object class="GtkAdjustment" id="adj_derot_radius">
    <property name="lower">1</property><property name="upper">10000</property>
    <property name="step-increment">1</property><property name="page-increment">10</property>
  </object>
  <object class="GtkAdjustment" id="adj_derot_pa">
    <property name="lower">-180</property><property name="upper">180</property>
    <property name="step-increment">0.5</property><property name="page-increment">5</property>
  </object>
  <object class="GtkAdjustment" id="adj_derot_fps">
    <property name="lower">0</property><property name="upper">10000</property>
    <property name="step-increment">1</property><property name="page-increment">10</property>
  </object>
  <object class="GtkWindow" id="derotation_dialog">
    <property name="title" translatable="yes">Planetary derotation</property>
    <property name="resizable">0</property>
    <property name="modal">0</property>
    <property name="destroy-with-parent">1</property>
    <signal name="close-request" handler="on_derotation_dialog_close_request" swapped="no"/>
    <signal name="show" handler="on_derotation_dialog_show" swapped="no"/>
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">12</property>
        <child>
          <object class="GtkGrid">
            <property name="row-spacing">6</property>
            <property name="column-spacing">10</property>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Target</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">0</property></layout></object>
            </child>
            <child>
              <object class="GtkDropDown" id="derot_body">
                <property name="model"><object class="GtkStringList"><items>
                  <item translatable="yes">Jupiter</item><item translatable="yes">Saturn</item><item translatable="yes">Mars</item>
                </items></object></property>
                <layout><property name="column">1</property><property name="row">0</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Rotation system</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">1</property></layout></object>
            </child>
            <child>
              <object class="GtkDropDown" id="derot_system">
                <property name="model"><object class="GtkStringList"><items>
                  <item>I</item><item>II</item><item>III</item>
                </items></object></property>
                <layout><property name="column">1</property><property name="row">1</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Reference epoch (UTC)</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">2</property></layout></object>
            </child>
            <child>
              <object class="GtkEntry" id="derot_epoch">
                <property name="tooltip-text" translatable="yes">YYYY-MM-DDTHH:MM:SS — defaults to the capture midpoint</property>
                <layout><property name="column">1</property><property name="row">2</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Frame rate (fps, if no timestamps)</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">3</property></layout></object>
            </child>
            <child>
              <object class="GtkSpinButton" id="derot_fps"><property name="adjustment">adj_derot_fps</property><property name="digits">2</property>
                <layout><property name="column">1</property><property name="row">3</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Disk centre X / Y (px)</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">4</property></layout></object>
            </child>
            <child>
              <object class="GtkBox"><property name="spacing">6</property>
                <child><object class="GtkSpinButton" id="derot_cx"><property name="adjustment">adj_derot_cx</property><property name="digits">1</property>
                  <signal name="value-changed" handler="on_derotation_value_changed" swapped="no"/></object></child>
                <child><object class="GtkSpinButton" id="derot_cy"><property name="adjustment">adj_derot_cy</property><property name="digits">1</property>
                  <signal name="value-changed" handler="on_derotation_value_changed" swapped="no"/></object></child>
                <layout><property name="column">1</property><property name="row">4</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Equatorial radius (px)</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">5</property></layout></object>
            </child>
            <child>
              <object class="GtkSpinButton" id="derot_radius"><property name="adjustment">adj_derot_radius</property><property name="digits">1</property>
                <signal name="value-changed" handler="on_derotation_value_changed" swapped="no"/>
                <layout><property name="column">1</property><property name="row">5</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">North-pole angle (deg)</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">6</property></layout></object>
            </child>
            <child>
              <object class="GtkSpinButton" id="derot_pa"><property name="adjustment">adj_derot_pa</property><property name="digits">2</property>
                <signal name="value-changed" handler="on_derotation_value_changed" swapped="no"/>
                <layout><property name="column">1</property><property name="row">6</property></layout></object>
            </child>
            <child>
              <object class="GtkCheckButton" id="derot_parity"><property name="label" translatable="yes">Mirrored image</property>
                <layout><property name="column">1</property><property name="row">7</property></layout></object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="derot_status"><property name="wrap">1</property><property name="xalign">0</property>
            <property name="label" translatable="yes">Fit the disk to the planet, then compute.</property></object>
        </child>
        <child>
          <object class="GtkBox"><property name="spacing">6</property><property name="halign">end</property>
            <child><object class="GtkButton" id="derot_autofit"><property name="label" translatable="yes">Auto-detect disk</property>
              <signal name="clicked" handler="on_derotation_autofit_clicked" swapped="no"/></object></child>
            <child><object class="GtkButton" id="derot_close"><property name="label" translatable="yes">Close</property>
              <signal name="clicked" handler="on_derotation_close_clicked" swapped="no"/></object></child>
            <child><object class="GtkButton" id="derot_compute"><property name="label" translatable="yes">Compute &amp; save</property>
              <signal name="clicked" handler="on_derotation_compute_clicked" swapped="no"/></object></child>
          </object>
        </child>
      </object>
    </property>
  </object>
</interface>
