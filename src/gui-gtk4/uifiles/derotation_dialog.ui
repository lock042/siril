<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkAdjustment" id="adj_derot_cx">
    <property name="lower">0</property><property name="upper">20000</property>
    <property name="step-increment">1</property><property name="page-increment">10</property>
  </object>
  <object class="GtkAdjustment" id="adj_derot_cy">
    <property name="lower">0</property><property name="upper">20000</property>
    <property name="step-increment">1</property><property name="page-increment">10</property>
  </object>
  <object class="GtkAdjustment" id="adj_derot_radius">
    <property name="lower">1</property><property name="upper">10000</property>
    <property name="step-increment">1</property><property name="page-increment">10</property>
  </object>
  <object class="GtkAdjustment" id="adj_derot_rpol">
    <property name="lower">1</property><property name="upper">10000</property>
    <property name="step-increment">1</property><property name="page-increment">10</property>
  </object>
  <object class="GtkAdjustment" id="adj_derot_pa">
    <property name="lower">-180</property><property name="upper">180</property>
    <property name="step-increment">0.5</property><property name="page-increment">5</property>
  </object>
  <object class="GtkAdjustment" id="adj_derot_fps">
    <property name="lower">0</property><property name="upper">10000</property>
    <property name="step-increment">1</property><property name="page-increment">10</property>
  </object>
  <object class="GtkWindow" id="derotation_dialog">
    <property name="title" translatable="yes">Planetary derotation</property>
    <property name="resizable">0</property>
    <property name="modal">0</property>
    <property name="destroy-with-parent">1</property>
    <signal name="close-request" handler="on_derotation_dialog_close_request" swapped="no"/>
    <signal name="show" handler="on_derotation_dialog_show" swapped="no"/>
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">12</property>
        <child>
          <object class="GtkGrid">
            <property name="row-spacing">6</property>
            <property name="column-spacing">10</property>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Target</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">0</property></layout></object>
            </child>
            <child>
              <object class="GtkDropDown" id="derot_body">
                <property name="tooltip-text" translatable="yes">The planet being captured. Sets the rotation model, the default rotation system and the disk oblateness used when fitting.</property>
                <property name="model"><object class="GtkStringList"><items>
                  <item translatable="yes">Jupiter</item><item translatable="yes">Saturn</item><item translatable="yes">Mars</item>
                </items></object></property>
                <layout><property name="column">1</property><property name="row">0</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Rotation system</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">1</property></layout></object>
            </child>
            <child>
              <object class="GtkDropDown" id="derot_system">
                <property name="tooltip-text" translatable="yes">Rotation system used to track features: I, II or III. The standard choice is filled in automatically for the selected planet (Jupiter II, Saturn III, Mars I); change it only to follow a feature in a different system.</property>
                <property name="model"><object class="GtkStringList"><items>
                  <item>I</item><item>II</item><item>III</item>
                </items></object></property>
                <layout><property name="column">1</property><property name="row">1</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Reference epoch (UTC)</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">2</property></layout></object>
            </child>
            <child>
              <object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">2</property>
                <child><object class="GtkEntry" id="derot_epoch">
                  <property name="tooltip-text" translatable="yes">YYYY-MM-DDTHH:MM:SS — defaults to the capture midpoint</property></object></child>
                <child><object class="GtkCheckButton" id="derot_epoch_lock">
                  <property name="label" translatable="yes">Shared epoch (keep for other sequences)</property>
                  <property name="tooltip-text" translatable="yes">Keep this reference epoch when you load another sequence, so several channels (e.g. R/G/B shot minutes apart) all derotate to the same instant and can then be combined in the Compositing tool (use its Planetary alignment). For the best result set the epoch to the midpoint of the whole session; the "derotate" command's -epoch-from option computes that automatically from a list of sequences.</property></object></child>
                <layout><property name="column">1</property><property name="row">2</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Frame rate (fps, if no timestamps)</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">3</property></layout></object>
            </child>
            <child>
              <object class="GtkSpinButton" id="derot_fps"><property name="adjustment">adj_derot_fps</property><property name="digits">2</property>
                <property name="tooltip-text" translatable="yes">Capture frame rate. Only used when the video carries no per-frame timestamps (SER files normally do); leave at 0 to use the embedded timestamps.</property>
                <layout><property name="column">1</property><property name="row">3</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Disk centre X / Y (px)</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">4</property></layout></object>
            </child>
            <child>
              <object class="GtkBox"><property name="spacing">6</property>
                <child><object class="GtkSpinButton" id="derot_cx"><property name="adjustment">adj_derot_cx</property><property name="digits">1</property>
                  <property name="tooltip-text" translatable="yes">Disk centre, X (pixels). You can also drag the disk on the image to move it.</property>
                  <signal name="value-changed" handler="on_derotation_value_changed" swapped="no"/></object></child>
                <child><object class="GtkSpinButton" id="derot_cy"><property name="adjustment">adj_derot_cy</property><property name="digits">1</property>
                  <property name="tooltip-text" translatable="yes">Disk centre, Y (pixels). You can also drag the disk on the image to move it.</property>
                  <signal name="value-changed" handler="on_derotation_value_changed" swapped="no"/></object></child>
                <layout><property name="column">1</property><property name="row">4</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">Equatorial / polar radius (px)</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">5</property></layout></object>
            </child>
            <child>
              <object class="GtkBox"><property name="spacing">6</property>
                <child><object class="GtkSpinButton" id="derot_radius"><property name="adjustment">adj_derot_radius</property><property name="digits">1</property>
                  <property name="tooltip-text" translatable="yes">Equatorial radius of the globe in pixels (for Saturn, the globe — not the rings). Drag the magenta handles on the image to resize.</property>
                  <signal name="value-changed" handler="on_derotation_value_changed" swapped="no"/></object></child>
                <child><object class="GtkSpinButton" id="derot_rpol"><property name="adjustment">adj_derot_rpol</property><property name="digits">1</property>
                  <property name="tooltip-text" translatable="yes">Polar radius in pixels; sets the disk oblateness. Defaults to the body's known flattening. Drag the yellow N/S handles on the image to adjust.</property>
                  <signal name="value-changed" handler="on_derotation_value_changed" swapped="no"/></object></child>
                <layout><property name="column">1</property><property name="row">5</property></layout></object>
            </child>
            <child>
              <object class="GtkLabel"><property name="label" translatable="yes">North-pole angle (deg)</property><property name="halign">start</property>
                <layout><property name="column">0</property><property name="row">6</property></layout></object>
            </child>
            <child>
              <object class="GtkSpinButton" id="derot_pa"><property name="adjustment">adj_derot_pa</property><property name="digits">2</property>
                <property name="tooltip-text" translatable="yes">In-image position angle of the planet's north pole, in degrees (0 = up, increasing clockwise). Drag the round handle at the "N" end of the axis on the image to rotate it.</property>
                <signal name="value-changed" handler="on_derotation_value_changed" swapped="no"/>
                <layout><property name="column">1</property><property name="row">6</property></layout></object>
            </child>
            <child>
              <object class="GtkCheckButton" id="derot_parity"><property name="label" translatable="yes">Mirrored image</property>
                <property name="tooltip-text" translatable="yes">Tick if the image is mirrored (flipped left-right, not merely rotated). This flips the east-west sense so features derotate the correct way. Mirroring comes from an odd number of reflections in the light path, and a conventional mirror-type star diagonal adds one. Imaging straight-through at prime focus — a refractor, Newtonian/reflector, Schmidt-Cassegrain, Ritchey-Chrétien or Maksutov — is not mirrored; the same refractor, SCT, RC or Mak used with a star diagonal is. If unsure, do a quick test stack and watch which way a known feature drifts.</property>
                <signal name="toggled" handler="on_derotation_parity_toggled" swapped="no"/>
                <layout><property name="column">1</property><property name="row">7</property></layout></object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="derot_status"><property name="wrap">1</property><property name="xalign">0</property>
            <property name="label" translatable="yes">Fit the disk to the planet, then compute.</property></object>
        </child>
        <child>
          <object class="GtkFrame">
            <property name="label" translatable="yes">Combine several sequences</property>
            <property name="margin-top">6</property>
            <child>
              <object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">4</property>
                <property name="margin-start">6</property><property name="margin-end">6</property>
                <property name="margin-top">6</property><property name="margin-bottom">6</property>
                <child>
                  <object class="GtkLabel"><property name="wrap">1</property><property name="xalign">0</property>
                    <property name="label" translatable="yes">Fit each sequence's disk, tag its channel and add it. Pick one as the reference (★) — it defines the shared frame all channels are stacked into. Then combine.</property></object>
                </child>
                <child>
                  <object class="GtkBox"><property name="spacing">6</property>
                    <child><object class="GtkDropDown" id="derot_channel">
                      <property name="tooltip-text" translatable="yes">Colour channel to tag the sequence being added. Use OSC for a one-shot-colour (CFA) camera — it stacks straight to colour. Mono sequences shot through R, G and B filters each get their own stack, ready to assemble into colour; use Mono for a single mono result.</property>
                      <property name="model"><object class="GtkStringList"><items>
                        <item translatable="yes">Mono</item>
                        <item translatable="yes">Red</item>
                        <item translatable="yes">Green</item>
                        <item translatable="yes">Blue</item>
                        <item translatable="yes">Luminance</item>
                        <item translatable="yes">OSC (one-shot color)</item>
                      </items></object></property></object></child>
                    <child><object class="GtkButton" id="derot_add"><property name="label" translatable="yes">Add current sequence</property>
                      <property name="hexpand">1</property><property name="halign">start</property>
                      <property name="tooltip-text" translatable="yes">Snapshot the loaded sequence with its current disk fit and the chosen channel into the session. Adding a sequence already in the list updates its fit.</property>
                      <signal name="clicked" handler="on_derotation_add_clicked" swapped="no"/></object></child>
                  </object>
                </child>
                <child>
                  <object class="GtkScrolledWindow"><property name="min-content-height">96</property>
                    <property name="has-frame">1</property><property name="vexpand">1</property>
                    <child><object class="GtkListBox" id="derot_seqlist">
                      <property name="selection-mode">single</property></object></child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox"><property name="spacing">6</property>
                    <child><object class="GtkButton" id="derot_setref"><property name="label" translatable="yes">Set as reference</property>
                      <property name="tooltip-text" translatable="yes">Make the selected sequence the reference. Its disk fit defines the common output frame every channel is stacked into, so the channels stay aligned for colour assembly.</property>
                      <signal name="clicked" handler="on_derotation_setref_clicked" swapped="no"/></object></child>
                    <child><object class="GtkButton" id="derot_remove"><property name="label" translatable="yes">Remove</property>
                      <property name="tooltip-text" translatable="yes">Remove the selected sequence from the session.</property>
                      <signal name="clicked" handler="on_derotation_remove_clicked" swapped="no"/></object></child>
                    <child><object class="GtkButton" id="derot_combine"><property name="label" translatable="yes">Combine sequences</property>
                      <property name="hexpand">1</property><property name="halign">end</property>
                      <property name="tooltip-text" translatable="yes">Build each sequence's derotation at the shared epoch and stack every channel into the reference frame, removing planetary rotation. Saves one image per channel; assemble colour with the compositing tools.</property>
                      <signal name="clicked" handler="on_derotation_combine_clicked" swapped="no"/></object></child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox"><property name="spacing">6</property><property name="halign">end</property>
            <child><object class="GtkButton" id="derot_autofit"><property name="label" translatable="yes">Auto-detect disk</property>
              <property name="tooltip-text" translatable="yes">Estimate the globe centre, radius and orientation from the current image. It is only a starting point — check it against the disk and adjust on the image before computing.</property>
              <signal name="clicked" handler="on_derotation_autofit_clicked" swapped="no"/></object></child>
            <child><object class="GtkButton" id="derot_flipnorth"><property name="label" translatable="yes">Flip N</property>
              <property name="tooltip-text" translatable="yes">Flip the north pole to the opposite end of the rotation axis. The auto-fit aligns the axis but cannot tell which pole is which, so use this if the "N" marker points to the wrong pole.</property>
              <signal name="clicked" handler="on_derotation_flipnorth_clicked" swapped="no"/></object></child>
            <child><object class="GtkButton" id="derot_close"><property name="label" translatable="yes">Close</property>
              <property name="tooltip-text" translatable="yes">Close the tool without computing. The fit is kept for next time.</property>
              <signal name="clicked" handler="on_derotation_close_clicked" swapped="no"/></object></child>
            <child><object class="GtkButton" id="derot_compute"><property name="label" translatable="yes">Compute &amp; save</property>
              <property name="tooltip-text" translatable="yes">Compute the per-frame derotation from the ephemeris and the fitted disk and save it next to the sequence. Then register and stack as usual; the result is picked up automatically.</property>
              <signal name="clicked" handler="on_derotation_compute_clicked" swapped="no"/></object></child>
          </object>
        </child>
      </object>
    </property>
  </object>
</interface>
