<?xml version='1.0' encoding='UTF-8'?>
<interface>
  <requires lib="gtk" version="4.0" />
  <object class="GtkAdjustment" id="adj_color_mask_feather">
    <property name="upper">100</property>
    <property name="step-increment">1</property>
    <property name="page-increment">5</property>
  </object>
  <object class="GtkAdjustment" id="adj_color_mask_lum_max">
    <property name="upper">1</property>
    <property name="value">1</property>
    <property name="step-increment">0.01</property>
    <property name="page-increment">0.10</property>
  </object>
  <object class="GtkAdjustment" id="adj_color_mask_lum_min">
    <property name="upper">1</property>
    <property name="step-increment">0.01</property>
    <property name="page-increment">0.10</property>
  </object>
  <object class="GtkAdjustment" id="adj_color_mask_tolerance">
    <property name="upper">1</property>
    <property name="value">0.14999999999999999</property>
    <property name="step-increment">0.01</property>
    <property name="page-increment">0.05</property>
  </object>
  <object class="GtkDialog" id="mask_from_color_dialog">
    <property name="width-request">600</property>
    <property name="height-request">500</property>
    <property name="title" translatable="1">Create Color Mask</property>
    <property name="resizable">0</property>
    <signal name="close-request" handler="siril_widget_hide_on_delete" swapped="no" />
    <signal name="hide" handler="on_mask_color_close_clicked" swapped="no" />
    <signal name="show" handler="on_mask_from_color_dialog_show" swapped="no" />
    <child internal-child="content_area">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">10</property>
        <child>
          <object class="GtkGrid">
            <property name="row-spacing">10</property>
            <property name="column-spacing">10</property>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="1">Bit Depth</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkDropDown" id="combo_color_mask_bitdepth">
                <property name="model">
                  <object class="GtkStringList">
                    <items>
                      <item translatable="yes">8-bit</item>
                      <item translatable="yes">16-bit</item>
                      <item translatable="yes">32-bit</item>
                    </items>
                  </object>
                </property>
                <property name="selected">1</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">10</property>
            <child>
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="label" translatable="1">&lt;b&gt;Target Chromaticity (Pure Color)&lt;/b&gt;</property>
                <property name="use-markup">1</property>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="spacing">10</property>
                <child>
                  <object class="GtkFrame">
                    <property name="child">
                      <object class="GtkDrawingArea" id="drawing_area_color_display">
                        <property name="width-request">100</property>
                        <property name="height-request">100</property>
                        <property name="tooltip-text" translatable="1">Selected color preview</property>
                      </object>
                    </property>
                    <child type="label">
                      <object class="GtkLabel">
                        <property name="label" translatable="1">Selected Color</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">5</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="halign">start</property>
                        <property name="label" translatable="1">&lt;i&gt;Click "Pick Color from Image" to select
a pixel from the image. The chromaticity
(pure color ratio) will be extracted
automatically, independent of brightness.&lt;/i&gt;</property>
                        <property name="use-markup">1</property>
                        <property name="wrap">1</property>
                        <property name="max-width-chars">30</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="button_pick_from_image">
                        <property name="label" translatable="1">Pick Color from Image</property>
                        <property name="focusable">1</property>
                        <property name="receives-default">1</property>
                        <property name="tooltip-text" translatable="1">Click to select a pixel from the image to use its color</property>
                        <signal name="clicked" handler="on_button_pick_from_image_clicked" swapped="no" />
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkGrid">
                <property name="vexpand">1</property>
                <property name="row-spacing">10</property>
                <property name="column-spacing">10</property>
                <child>
                  <object class="GtkLabel">
                    <property name="tooltip-text" translatable="1">How far from the target color to accept (0.0 = exact match, 1.0 = very broad)</property>
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Color Tolerance</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkScale" id="scale_color_tolerance">
                    <property name="draw-value">1</property>
                    <property name="focusable">1</property>
                    <property name="hexpand">1</property>
                    <property name="adjustment">adj_color_mask_tolerance</property>
                    <property name="digits">2</property>
                    <property name="value-pos">right</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="tooltip-text" translatable="1">Minimum brightness (0.0 = black, 1.0 = white)</property>
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Luminance Min</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkScale" id="scale_lum_min">
                    <property name="draw-value">1</property>
                    <property name="focusable">1</property>
                    <property name="hexpand">1</property>
                    <property name="adjustment">adj_color_mask_lum_min</property>
                    <property name="digits">2</property>
                    <property name="value-pos">right</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="tooltip-text" translatable="1">Maximum brightness (0.0 = black, 1.0 = white)</property>
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Luminance Max</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">2</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkScale" id="scale_lum_max">
                    <property name="draw-value">1</property>
                    <property name="focusable">1</property>
                    <property name="hexpand">1</property>
                    <property name="adjustment">adj_color_mask_lum_max</property>
                    <property name="digits">2</property>
                    <property name="value-pos">right</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">2</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkSeparator" />
        </child>
        <child>
          <object class="GtkGrid">
            <property name="row-spacing">10</property>
            <property name="column-spacing">10</property>
            <child>
              <object class="GtkLabel">
                <property name="tooltip-text" translatable="1">Smooths mask edges. 0 = hard edges, higher = softer transitions</property>
                <property name="halign">start</property>
                <property name="label" translatable="1">Feather Radius (px)</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="spin_color_feather">
                <property name="focusable">1</property>
                <property name="adjustment">adj_color_mask_feather</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="toggle_color_mask_invert">
            <property name="label" translatable="1">Invert mask</property>
            <property name="focusable">1</property>
            <property name="tooltip-text" translatable="1">If checked, the mask will be inverted</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="toggle_color_mask_cleanup">
            <property name="label" translatable="1">Clean up mask</property>
            <property name="focusable">1</property>
            <property name="tooltip-text" translatable="1">If checked, morphological operations are carried out to clean up the mask to remove isolated noise and small holes in the mask. This is slower to compute but may give a nicer mask</property>
          </object>
        </child>
      </object>
    </child>
    <action-widgets>
      <action-widget response="0">mask_color_apply</action-widget>
    </action-widgets>
    <child internal-child="action_area">
      <object class="GtkBox">
        <property name="spacing">6</property>
        <property name="halign">end</property>
        <property name="orientation">horizontal</property>
        <child>
          <object class="GtkButton" id="mask_color_close">
            <property name="label" translatable="1">Close</property>
            <property name="focusable">1</property>
            <property name="receives-default">1</property>
            <signal name="clicked" handler="on_mask_color_close_clicked" swapped="no" />
          </object>
        </child>
        <child>
          <object class="GtkButton" id="mask_color_apply">
            <property name="label" translatable="1">Apply</property>
            <property name="focusable">1</property>
            <property name="receives-default">1</property>
            <signal name="clicked" handler="on_mask_color_apply_clicked" swapped="no" />
            <style>
              <class name="suggested-action" />
            </style>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>